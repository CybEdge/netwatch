                    continue
                if isinstance(val, bool):
                    toggle_items.append((path, label, val))

            opt_lines: list[str] = []
            opt_attrs: list[int] = []
            for i, (path, label, val) in enumerate(toggle_items):
                mark = "ON " if val else "OFF"
                line = f"[{mark}] {label}"
                opt_lines.append(line[: left_w - 4])
                if pane == "settings" and i == sel:
                    attr = cp(CP_CYAN, bold=True)
                else:
                    attr = cp(CP_WHITE, dim=True)
                opt_attrs.append(attr)
            sel = min(sel, max(0, len(toggle_items) - 1))
            put_lines(stdscr, 3, 2, left_w - 4, opt_lines, cp(CP_WHITE), line_attrs=opt_attrs)

            draw_cyber_panel(stdscr, 2, left_w + 1, h - 4, w - left_w - 2, keys_title, pair=CP_MAGENTA)
            kb_items = binding_rows(cfg)
            kb_lines: list[str] = []
            kb_attrs: list[int] = []
            for i, (_action, key, desc) in enumerate(kb_items):
                mark = "▸" if pane == "keys" and i == kb_sel else " "
                kb_lines.append(f"{mark}{key:<7} {desc}"[: w - left_w - 6])
                if pane == "keys" and i == kb_sel:
                    kb_attrs.append(cp(CP_MAGENTA, bold=True))
                else:
                    kb_attrs.append(cp(CP_MAGENTA, dim=True))
            kb_sel = min(kb_sel, max(0, len(kb_items) - 1))
            put_lines(
                stdscr,
                3,
                left_w + 3,
                w - left_w - 6,
                kb_lines,
                cp(CP_MAGENTA, dim=True),
                line_attrs=kb_attrs,
            )

            draw_cyber_footer(stdscr, h - 1, w, footer, cfg)
            stdscr.refresh()

            if capture_action:
                stdscr.timeout(-1)
                ch = stdscr.getch()
                stdscr.timeout(IDLE_TIMEOUT_MS)
                if ch in (27,):
                    capture_action = None
                    ui_status.flash("rebind cancelled")
                    continue
                msg = set_keybinding(cfg, capture_action, ch)
                capture_action = None
                ui_status.flash(msg)
                continue

            ch = stdscr.getch()
            if ch == -1:
                continue
            if ch in (ord("q"), ord("Q"), 27):
                cyber_screen_exit(stdscr)
                return ""
            if ch in (ord("s"), ord("S")):
                save_config(cfg)
                cyber_screen_exit(stdscr)
                return "options saved — press R to reload"
            if ch == 9:
                pane = "keys" if pane == "settings" else "settings"
                continue
            if ch in (curses.KEY_UP, ord("k")):
                if pane == "settings":
                    sel = max(0, sel - 1)
                else:
                    kb_sel = max(0, kb_sel - 1)
            if ch in (curses.KEY_DOWN, ord("j")):
                if pane == "settings":
                    sel = min(len(opt_lines) - 1, sel + 1)
                else:
                    kb_sel = min(len(kb_items) - 1, kb_sel + 1)
            if ch in (10, 13, ord(" ")):
                if pane == "settings" and toggle_items:
                    path, _label, val = toggle_items[sel]
                    cfg_set(cfg, path, not val)
                    ui_status.flash(f"toggled {'.'.join(path)}")
                elif pane == "keys" and kb_items:
                    capture_action = kb_items[kb_sel][0]
    finally:
        stdscr.timeout(IDLE_TIMEOUT_MS)


def paginate_slice(
    items: list[Any],
    scroll: int,
    *,
    page_sz: int,
    max_rows: int,
) -> tuple[list[Any], int, int]:
    cap = max(1, min(page_sz, max_rows))
    total = len(items)
    if total == 0:
        return [], 0, 0
    max_scroll = max(0, total - cap)
    scroll = max(0, min(scroll, max_scroll))
    return items[scroll : scroll + cap], scroll, total


def panel_scroll_label(scroll: int, visible: int, total: int) -> str:
    if total <= visible:
        return ""
    end = min(scroll + visible, total)
    return f" [{scroll + 1}-{end}/{total}]"


def advance_scroll(scroll: int, page_sz: int, total: int, max_rows: int) -> int:
    cap = max(1, min(page_sz, max_rows))
    if total <= cap:
        return 0
    max_scroll = max(0, total - cap)
    next_scroll = scroll + page_sz
    return 0 if next_scroll > max_scroll else next_scroll


def retreat_scroll(scroll: int, page_sz: int) -> int:
    return max(0, scroll - page_sz)


def unknown_devices(devices: list[LanDevice], cfg: dict[str, Any]) -> list[LanDevice]:
    return [d for d in devices if d.is_new and not is_blocked_mac(cfg, d.mac)]


def quarantine_lines(blocked: list[BlockedEntry], limit: int = 4) -> list[str]:
    if not blocked:
        return ["◈ quarantine · empty"]
    online = sum(1 for b in blocked if b.online)
    lines = [f"◈ quarantine · {len(blocked)} blocked · {online} online"]
    for entry in blocked[:limit]:
        glyph = "◉ ONLINE" if entry.online else "○ offline"
        name = (entry.label or entry.mac)[:14]
        lines.append(f"  {name:<14} {entry.last_ip} {glyph}")
    if len(blocked) > limit:
        lines.append(f"  … +{len(blocked) - limit} more")
    return lines


def status_flash_seconds(cfg: dict[str, Any]) -> float:
    try:
        return max(0.5, float(cfg.get("display", {}).get("status_flash_seconds") or STATUS_FLASH_SEC))
    except (TypeError, ValueError):
        return STATUS_FLASH_SEC


class FlashStatus:
    """Transient footer/hud messages that revert to the key legend after a timeout."""

    def __init__(self, legend: str, *, ttl: float = STATUS_FLASH_SEC):
        self.legend = legend
        self.ttl = ttl
        self._flash = ""
        self._until = 0.0

    def flash(self, msg: str, ttl: float | None = None) -> None:
        text = (msg or "").strip()
        if not text or text == self.legend:
            return
        self._flash = text
        self._until = time.monotonic() + (self.ttl if ttl is None else ttl)

    def current(self) -> str:
        if self._flash and time.monotonic() < self._until:
            return self._flash
        self._flash = ""
        return self.legend


def draw_cyber_footer(win, y: int, w: int, status: str, cfg: dict[str, Any] | None = None) -> None:
    if y >= win.getmaxyx()[0] - 1 or w < 10:
        return
    keys = dashboard_footer_keys(cfg) if cfg else " W/w·panels  O·opts  B·block  G·list  R·sync  H·?  Q·exit "
    msg = f" ▸ {status} "
    safe_addstr(win, y, 0, msg[: w - len(keys) - 1], cp(CP_GREEN))
    safe_addstr(win, y, max(0, w - len(keys) - 1), keys[: w - 1], cp(CP_CYAN, dim=True))


def put_lines(
    win,
    y: int,
    x: int,
    w: int,
    lines: list[str],
    attr: int = 0,
    *,
    line_attrs: list[int] | None = None,
) -> int:
    row = y
    max_y = win.getmaxyx()[0] - 1
    for i, line in enumerate(lines):
        if row >= max_y:
            break
        line_attr = line_attrs[i] if line_attrs and i < len(line_attrs) else attr
        safe_addstr(win, row, x, line[: max(0, w - 1)], line_attr, w)
        row += 1
    return row


def prompt_line(
    stdscr,
    y: int,
    text: str,
    w: int,
    *,
    restore_timeout_ms: int = IDLE_TIMEOUT_MS,
) -> str:
    """Read one line of input — blocks until Enter (immune to idle flash timeouts)."""
    curses.echo()
    curses.curs_set(1)
    try:
        stdscr.timeout(-1)
        stdscr.move(y, 0)
        stdscr.clrtoeol()
        safe_addstr(stdscr, y, 0, text[: w - 1], cp(CP_YELLOW, bold=True), w)
        stdscr.refresh()
        raw = stdscr.getstr(y, len(text), w - len(text) - 1)
        return raw.decode("utf-8", errors="replace").strip()
    finally:
        stdscr.timeout(restore_timeout_ms)
        curses.noecho()
        curses.curs_set(0)


def help_line_attr(line: str) -> int:
    if line.startswith("──"):
        return cp(CP_MAGENTA, bold=True)
    if line.startswith("NETWATCH"):
        return cp(CP_CYAN, bold=True)
    if line.startswith("  ") and any(k in line for k in ("Press", "Unknown MAC", "Tip:")):
        return cp(CP_YELLOW, dim=True)
    if line.startswith("    ") or line.startswith("  "):
        return cp(CP_GREEN, dim=True)
    return cp(CP_WHITE, dim=True)


def identify_rows(
    devices: list[LanDevice], width: int, cfg: dict[str, Any] | None = None
) -> tuple[list[str], list[int]]:
    header = f"{'#':>2}  {'IP':<15} {'NAME/GUESS':<16} {'VENDOR':<14} {'MAC':<17} NOTES"
    sep = "──" + ("─" * min(width - 3, len(header) - 2))
    rows = [header, sep]
    attrs = [cp(CP_CYAN, bold=True), cp(CP_MAGENTA, dim=True)]
    for i, d in enumerate(devices, 1):
        mark = "▸" if d.is_new else " "
        if cfg and is_blocked_mac(cfg, d.mac):
            mark = "⛔"
        name = (d.label or d.guess)[:16]
        vendor = (d.vendor or "?")[:14]
        notes = d.notes or d.state
        if d.hostname and not d.label:
            notes = f"{d.hostname[:20]} {notes}".strip()
        rows.append(
            f"{mark}{i:>2}  {d.ip:<15} {name:<16} {vendor:<14} {d.mac} {notes}"[: width - 1]
        )
        if cfg and is_blocked_mac(cfg, d.mac):
            attrs.append(cp(CP_YELLOW, bold=True))
        elif d.is_new:
            attrs.append(cp(CP_ALERT, bold=True))
        elif d.label:
            attrs.append(cp(CP_GREEN))
        else:
            attrs.append(cp(CP_WHITE, dim=True))
    return rows, attrs


def quick_block_unknown(stdscr, cfg: dict[str, Any], devices: list[LanDevice]) -> str:
    unknown = unknown_devices(devices, cfg)
    if not unknown:
        return "no unknown devices — press G for block registry"
    cyber_screen_enter(stdscr, "QUARANTINE")
    h, w = stdscr.getmaxyx()
    lines = [f"{i + 1}. {d.ip}  {d.mac}  {d.guess or d.vendor or '?'}" for i, d in enumerate(unknown[:12])]
    stdscr.erase()
    draw_cyber_hud_bar(stdscr, 0, w, " QUARANTINE // block unknown device ", "q·cancel", pair=CP_ALERT)
    put_lines(stdscr, 2, 2, w - 4, lines, cp(CP_ALERT, bold=True))
    num = prompt_line(stdscr, h - 3, "▸ row # to QUARANTINE (cut + registry): ", w)
    if not num.isdigit():
