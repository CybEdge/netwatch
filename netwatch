def html_unescape(text: str) -> str:
    return (
        text.replace("&quot;", '"')
        .replace("&#39;", "'")
        .replace("&amp;", "&")
        .replace("&lt;", "<")
        .replace("&gt;", ">")
    )


def json_path(data: Any, path: str) -> Any:
    cur = data
    for part in path.split("."):
        if not isinstance(cur, dict):
            return None
        cur = cur.get(part)
    return cur


def build_probe_context(
    dev: LanDevice,
    router_by_ip: dict[str, str],
    json_data: dict[str, Any] | None = None,
) -> dict[str, Any]:
    hostname = (dev.hostname or "").strip()
    short = hostname.split(".")[0] if hostname else ""
    router_name = (router_by_ip.get(dev.ip) or "").strip()
    ctx: dict[str, Any] = {
        "ip": dev.ip,
        "mac": dev.mac,
        "hostname": hostname,
        "hostname_short": short,
        "hostname_lower": hostname.lower(),
        "vendor": dev.vendor or "",
        "router_name": router_name,
        "random_mac": is_random_mac(dev.mac),
        "json": json_data or {},
    }
    if json_data:
        for key, value in json_data.items():
            if isinstance(value, (str, int, float, bool)):
                ctx[key] = value
    return ctx


def render_probe_template(text: str, ctx: dict[str, Any]) -> str:
    if not text:
        return ""

    def repl(match: re.Match[str]) -> str:
        key = match.group(1).strip()
        if key in ctx and ctx[key] is not None:
            val = ctx[key]
        else:
            val = json_path(ctx.get("json", {}), key)
        return "" if val is None else str(val)

    return re.sub(r"\{([^}]+)\}", repl, text)


def harness_when_matches(when: dict[str, Any], dev: LanDevice, ctx: dict[str, Any]) -> bool:
    if not when:
        return True
    if when.get("random_mac") is True and not ctx["random_mac"]:
        return False
    if when.get("random_mac") is False and ctx["random_mac"]:
        return False
    if when.get("hostname_empty") and ctx["hostname"]:
        return False
    if when.get("hostname_present") and not ctx["hostname"]:
        return False
    if when.get("vendor_present") and not ctx["vendor"]:
        return False
    port = when.get("port_open")
    if port is not None and not probe_tcp_port(dev.ip, int(port)):
        return False
    any_ports = when.get("any_port_open") or when.get("any_port")
    if any_ports:
        if not any(probe_tcp_port(dev.ip, int(p)) for p in any_ports):
            return False
    keywords = when.get("hostname_contains_any") or []
    if keywords:
        host = ctx["hostname_lower"]
        if not host or not any(k.lower() in host for k in keywords):
            return False
    return True


def load_harnesses(cfg: dict[str, Any]) -> list[dict[str, Any]]:
    if not cfg.get("harnesses", {}).get("enabled", True):
        return []
    directory = expand_path(cfg["harnesses"].get("directory") or str(HARNESS_DIR))
    if not directory.is_dir() or yaml is None:
        return []
    harnesses: list[dict[str, Any]] = []
    for path in sorted(directory.glob("*.yaml")) + sorted(directory.glob("*.yml")):
        try:
            doc = yaml.safe_load(path.read_text()) or {}
        except Exception:
            continue
        if not isinstance(doc, dict) or doc.get("enabled", True) is False:
            continue
        doc["_path"] = str(path)
        doc.setdefault("priority", 0)
        doc.setdefault("id", path.stem)
        harnesses.append(doc)
    harnesses.sort(key=lambda h: int(h.get("priority") or 0), reverse=True)
    return harnesses


def run_probe_harness(
    harness: dict[str, Any],
    dev: LanDevice,
    router_by_ip: dict[str, str],
) -> ProbeResult:
    hid = str(harness.get("id") or "?")
    when = harness.get("when") or {}
    probe = harness.get("probe") or {}
    result_tpl = harness.get("result") or {}
    ctx = build_probe_context(dev, router_by_ip)
    if not harness_when_matches(when, dev, ctx):
        return ProbeResult(matched=False, harness_id=hid)

    ptype = (probe.get("type") or "static").lower()
    json_data: dict[str, Any] | None = None

    if ptype == "router_name":
        if not ctx["router_name"] or ctx["router_name"] in ("?", "arp-neighbor"):
            return ProbeResult(matched=False, harness_id=hid)
        ctx["matched"] = True
    elif ptype == "hostname_map":
        if not ctx["hostname"]:
            return ProbeResult(matched=False, harness_id=hid)
    elif ptype == "http_json":
        url = render_probe_template(str(probe.get("url") or ""), ctx)
        if not url:
            return ProbeResult(matched=False, harness_id=hid)
        timeout = float(probe.get("timeout") or 1.5)
        try:
            with urlopen(url, timeout=timeout) as resp:
                json_data = json.loads(resp.read().decode("utf-8", errors="replace"))
        except (URLError, json.JSONDecodeError, TimeoutError, OSError):
            return ProbeResult(matched=False, harness_id=hid)
        ctx = build_probe_context(dev, router_by_ip, json_data if isinstance(json_data, dict) else {})
        for rule in harness.get("match") or []:
            val = json_path(ctx["json"], str(rule.get("path") or ""))
            expected = rule.get("equals")
            if expected is not None and str(val) != str(expected):
                return ProbeResult(matched=False, harness_id=hid)
    elif ptype == "tcp_map":
        timeout = float(probe.get("timeout") or 0.35)
        ports = probe.get("ports") or {}
        for port_str, spec in ports.items():
            if probe_tcp_port(dev.ip, int(port_str), timeout):
                result_tpl = spec if isinstance(spec, dict) else result_tpl
                break
        else:
            result_tpl = probe.get("default") or result_tpl
    elif ptype == "vendor_map":
        vendor = (dev.vendor or "").lower()
        if not vendor:
            return ProbeResult(matched=False, harness_id=hid)
        matched_rule = None
        for rule in probe.get("rules") or []:
            if str(rule.get("contains") or "").lower() in vendor:
                matched_rule = rule
                break
        result_tpl = matched_rule or probe.get("default") or result_tpl
        if not matched_rule and not probe.get("default"):
            return ProbeResult(matched=False, harness_id=hid)
    elif ptype == "script":
        script = expand_path(str(probe.get("path") or ""))
        if not script.is_file():
            return ProbeResult(matched=False, harness_id=hid, note=f"missing script {script}")
        env = os.environ.copy()
        env.update(
            {
                "NETWATCH_IP": dev.ip,
                "NETWATCH_MAC": dev.mac,
                "NETWATCH_HOSTNAME": dev.hostname or "",
                "NETWATCH_VENDOR": dev.vendor or "",
            }
        )
        try:
            proc = subprocess.run(
                [str(script)],
                capture_output=True,
                text=True,
                timeout=int(probe.get("timeout") or 10),
                check=False,
                env=env,
            )
            payload = json.loads((proc.stdout or "").strip() or "{}")
        except (json.JSONDecodeError, subprocess.TimeoutExpired):
            return ProbeResult(matched=False, harness_id=hid)
        if not payload.get("matched"):
            return ProbeResult(matched=False, harness_id=hid)
        return ProbeResult(
            matched=True,
            harness_id=hid,
            device_type=str(payload.get("device_type") or ""),
            auto_guess=str(payload.get("auto_guess") or ""),
            note=str(payload.get("note") or ""),
            confidence=float(payload.get("confidence") or 0.8),
        )
    elif ptype != "static":
        return ProbeResult(matched=False, harness_id=hid, note=f"unknown probe type {ptype}")

    transforms = result_tpl if isinstance(result_tpl, dict) else (harness.get("result") or {})
    auto_guess = render_probe_template(str(transforms.get("auto_guess") or ""), ctx)
    note = render_probe_template(str(transforms.get("note") or ""), ctx)
    device_type = render_probe_template(str(transforms.get("device_type") or ""), ctx)
    transform = transforms.get("transform") or (harness.get("result") or {}).get("transform") or {}
    if transform.get("auto_guess") == "html_unescape":
        auto_guess = html_unescape(auto_guess)

    if not auto_guess and not device_type and ptype != "static":
        return ProbeResult(matched=False, harness_id=hid)

    return ProbeResult(
        matched=True,
        harness_id=hid,
        device_type=device_type,
        auto_guess=auto_guess,
        note=note or hid,
        confidence=float(transforms.get("confidence") or (harness.get("result") or {}).get("confidence") or 0.7),
    )


def run_probe_harnesses(
    dev: LanDevice,
    router_by_ip: dict[str, str],
    cfg: dict[str, Any],
) -> tuple[str, str, str, str]:
    """Return device_type, auto_guess, note, harness_id."""
    harnesses = load_harnesses(cfg)
    stop_first = cfg.get("harnesses", {}).get("stop_on_first_match", True)
    best = ProbeResult(matched=False)
    for harness in harnesses:
        result = run_probe_harness(harness, dev, router_by_ip)
        if not result.matched:
            continue
        if stop_first:
            return result.device_type, result.auto_guess, result.note, result.harness_id
        if result.confidence >= best.confidence:
            best = result
    if best.matched:
        return best.device_type, best.auto_guess, best.note, best.harness_id
    return "unknown", "unknown device", "no harness matched", ""


def auto_probe_device(
    dev: LanDevice,
    router_by_ip: dict[str, str],
    cfg: dict[str, Any],
) -> tuple[str, str, str]:
    dtype, guess, note, _hid = run_probe_harnesses(dev, router_by_ip, cfg)
    return dtype, guess, note


def load_known(path: Path) -> dict[str, dict]:
    if not path.is_file():
        return {}
    try:
        data = json.loads(path.read_text())
        return data if isinstance(data, dict) else {}
    except json.JSONDecodeError:
        return {}


def save_known(path: Path, known: dict[str, dict]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(known, indent=2, sort_keys=True) + "\n")


def load_manual_map() -> dict[str, dict]:
    if not MANUAL_PATH.is_file():
        return {}
    try:
        items = json.loads(MANUAL_PATH.read_text())
    except json.JSONDecodeError:
        return {}
    by_mac: dict[str, dict] = {}
    for item in items if isinstance(items, list) else []:
        mac = str(item.get("mac", "")).lower()
        if mac:
            by_mac[mac] = item
    return by_mac


def save_manual_from_known(known: dict[str, dict]) -> None:
    rows = []
    for mac, entry in sorted(known.items()):
        label = (entry.get("label") or "").strip()
        if not label:
            continue
        rows.append(
            {
                "ip": entry.get("last_ip", "?"),
                "mac": mac,
                "name": label,
            }
        )
    MANUAL_PATH.parent.mkdir(parents=True, exist_ok=True)
    MANUAL_PATH.write_text(json.dumps(rows, indent=2) + "\n")


def set_device_label(cfg: dict[str, Any], mac: str, label: str) -> None:
    mac = mac.lower()
    known_path = expand_path(cfg["alerts"]["state_file"])
    known = load_known(known_path)
    entry = known.get(mac, {})
    entry["label"] = label.strip()
    entry.setdefault("first_seen", time.strftime("%Y-%m-%dT%H:%M:%S"))
    entry["last_seen"] = time.strftime("%Y-%m-%dT%H:%M:%S")
    known[mac] = entry
    save_known(known_path, known)
    save_manual_from_known(known)


def merge_manual_labels(cfg: dict[str, Any]) -> int:
    known_path = expand_path(cfg["alerts"]["state_file"])
    known = load_known(known_path)
    manual = load_manual_map()
    merged = 0
    for mac, item in manual.items():
        name = str(item.get("name", "")).strip()
        if not name or name in ("arp-neighbor", "?"):
            continue
        entry = known.setdefault(mac, {})
        if not (entry.get("label") or "").strip():
            entry["label"] = name
            merged += 1
        known[mac] = entry
    save_known(known_path, known)
    return merged


def enrich_devices(
    devices: list[LanDevice],
    known: dict[str, dict],
    router_clients: list[RouterClient],
    cfg: dict[str, Any],
    *,
    force_refresh: bool = False,
    network: bool = True,
) -> None:
    _, gateway, _ = default_route()
    router_by_mac = {c.mac.lower(): c.name for c in router_clients}
    router_by_ip = {
        c.ip: c.name
        for c in router_clients
        if c.ip.count(".") == 3 and c.name not in ("?", "arp-neighbor")
    }
    auto = cfg.get("identify", {}).get("auto_enrich", True)
    auto_probe = cfg.get("identify", {}).get("auto_probe_unknown", True)
    probe_interval = int(cfg.get("identify", {}).get("probe_interval_seconds") or 300)
    resolve_timeout = float(cfg.get("identify", {}).get("resolve_timeout_seconds") or 1.0)
    now_ts = time.time()
    now_str = time.strftime("%Y-%m-%dT%H:%M:%S")

    for dev in devices:
        entry = known.get(dev.mac, {})
        dev.label = (entry.get("label") or "").strip()
        dev.hostname = (entry.get("hostname") or "").strip()
        dev.vendor = (entry.get("vendor") or "").strip()
        auto_guess = (entry.get("auto_guess") or "").strip()
        device_type = (entry.get("device_type") or "").strip()

        if not dev.label and dev.mac in router_by_mac:
            name = router_by_mac[dev.mac]
            if name not in ("?", "arp-neighbor"):
                dev.label = name

        if network and auto:
            if force_refresh or not dev.hostname:
                host = resolve_hostname(dev.ip, resolve_timeout)
                if host:
                    dev.hostname = host
                    entry["hostname"] = host

            if force_refresh or (not dev.vendor and not is_random_mac(dev.mac)):
                vendor = lookup_vendor(dev.mac, cfg)
                if vendor:
                    dev.vendor = vendor
                    entry["vendor"] = vendor

        probed_at = float(entry.get("probed_at") or 0)
        unknown = not dev.label
        stale = (now_ts - probed_at) > probe_interval
        should_probe = auto_probe and unknown and network and (
            force_refresh or dev.is_new or stale or not auto_guess
        )

        if should_probe:
            dtype, guess, probe_note, harness_id = run_probe_harnesses(
                dev, router_by_ip, cfg
            )
            if guess and (force_refresh or not auto_guess):
                auto_guess = guess
            elif guess and not auto_guess:
                auto_guess = guess
            if dtype:
                device_type = dtype
            entry["auto_guess"] = auto_guess
            entry["device_type"] = device_type
            entry["probe_note"] = probe_note
            entry["harness_id"] = harness_id
            entry["probed_at"] = now_ts

        notes: list[str] = []
        if dev.ip == gateway:
            notes.append("gateway")
        if is_random_mac(dev.mac):
            notes.append("random MAC")
        if dev.is_new:
            notes.append("NEW")
        if device_type and not dev.label:
            notes.append(device_type)
        probe_note = (entry.get("probe_note") or "").strip()
        if probe_note and probe_note not in notes and len(notes) < 4:
            notes.append(probe_note[:24])
        dev.notes = ", ".join(notes)

        short_host = dev.hostname.split(".")[0] if dev.hostname else ""
        dev.guess = dev.label or auto_guess or short_host or dev.vendor or "unknown device"
        entry["last_ip"] = dev.ip
        entry["last_seen"] = now_str
        known[dev.mac] = entry


def device_needs_attention(
    dev: LanDevice, known: dict[str, dict], cfg: dict[str, Any]
) -> bool:
    """Stay flagged until the user labels, acknowledges, or blocks the device."""
    if is_blocked_mac(cfg, dev.mac):
        return False
    entry = known.get(dev.mac) or {}
    if entry.get("acknowledged"):
        return False
    label = (dev.label or entry.get("label") or "").strip()
    return not label


def update_known(
    known: dict[str, dict], devices: list[LanDevice], acknowledge: bool
) -> dict[str, dict]:
    now = time.strftime("%Y-%m-%dT%H:%M:%S")
    for dev in devices:
        entry = known.get(dev.mac, {})
        if not entry:
            entry = {"first_seen": now, "acknowledged": False}
        entry["last_seen"] = now
        entry["last_ip"] = dev.ip
        if dev.label:
            entry["label"] = dev.label
        if dev.hostname:
            entry["hostname"] = dev.hostname
        if dev.vendor:
            entry["vendor"] = dev.vendor
        if acknowledge:
            entry["acknowledged"] = True
        known[dev.mac] = entry
    return known


def scan_cidrs(cfg: dict[str, Any], local_ip: str) -> list[str]:
    primary = cfg.get("scan", {}).get("cidr") or str(
        ipaddress.ip_network(f"{local_ip}/24", strict=False)
    )
    cidrs = [primary]
    for extra in cfg.get("scan", {}).get("extra_cidrs") or []:
        if extra and extra not in cidrs:
            cidrs.append(str(extra))
    return cidrs


def ping_host(ip: str, iface: str) -> str | None:
    code = subprocess.call(
        ["ping", "-c", "1", "-W", "1", "-I", iface, ip],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    return ip if code == 0 else None


def ping_sweep(cidr: str, iface: str, limit: int, workers: int = 48) -> set[str]:
    alive: set[str] = set()
    try:
        net = ipaddress.ip_network(cidr, strict=False)
    except ValueError:
        return alive
    hosts = [str(h) for h in net.hosts()]
    if limit and limit > 0:
        hosts = hosts[:limit]
    workers = max(1, min(workers, 64))
    with ThreadPoolExecutor(max_workers=workers) as pool:
        futures = [pool.submit(ping_host, ip, iface) for ip in hosts]
        for fut in as_completed(futures):
            ip = fut.result()
            if ip:
                alive.add(ip)
    return alive


def mdns_discover(timeout: int = 4) -> dict[str, str]:
    """Return {ip: hostname} from avahi-browse."""
    if not shutil.which("avahi-browse"):
        return {}
    try:
        proc = subprocess.run(
            ["avahi-browse", "-a", "-r", "-t"],
            capture_output=True,
            text=True,
            timeout=max(2, timeout),
            check=False,
        )
    except subprocess.TimeoutExpired:
        return {}
    found: dict[str, str] = {}
    current_name = ""
    for line in (proc.stdout or "").splitlines():
        if line.startswith("="):
            parts = line.split(";")
            if len(parts) >= 4:
                current_name = parts[3].strip()
        elif "address =" in line:
            m = re.search(r"\[(\d+\.\d+\.\d+\.\d+)\]", line)
            if m:
                ip = m.group(1)
                found[ip] = current_name or found.get(ip, "")
        elif line.startswith("+") and "IPv4" in line:
            parts = line.split(";")
            if len(parts) >= 4:
                current_name = parts[3].strip()
    return found


def nmap_discover(cidr: str) -> set[str]:
    if not shutil.which("nmap"):
        return set()
    out = run(["nmap", "-sn", "-T4", "--max-retries", "1", cidr], timeout=180)
    alive: set[str] = set()
    for line in out.splitlines():
        m = re.search(r"Nmap scan report for (?:.* \()?(\d+\.\d+\.\d+\.\d+)", line)
        if not m:
            m = re.search(r"Nmap scan report for (\d+\.\d+\.\d+\.\d+)", line)
        if m:
            alive.add(m.group(1))
    return alive


def house_scan(cfg: dict[str, Any], iface: str, local_ip: str) -> tuple[set[str], str]:
    """Discover devices across configured subnets. Returns (ips, summary)."""
    methods = [str(m).lower() for m in (cfg.get("scan", {}).get("methods") or ["ping", "mdns"])]
    limit = int(cfg.get("scan", {}).get("ping_limit") or 0)
    workers = int(cfg.get("scan", {}).get("ping_workers") or 48)
    mdns_timeout = int(cfg.get("scan", {}).get("mdns_timeout_seconds") or 4)
    use_nmap = cfg.get("scan", {}).get("use_nmap_if_available", True)

    all_ips: set[str] = set()
    parts: list[str] = []

    cidrs = scan_cidrs(cfg, local_ip)
    if "ping" in methods:
        ping_hits: set[str] = set()
        for cidr in cidrs:
            ping_hits |= ping_sweep(cidr, iface, limit, workers)
        all_ips |= ping_hits
        parts.append(f"ping {len(ping_hits)}")

    if "mdns" in methods:
        mdns = mdns_discover(mdns_timeout)
        all_ips |= set(mdns.keys())
        parts.append(f"mdns {len(mdns)}")

    if use_nmap and shutil.which("nmap"):
        nmap_hits: set[str] = set()
        for cidr in cidrs:
            nmap_hits |= nmap_discover(cidr)
        all_ips |= nmap_hits
        parts.append(f"nmap {len(nmap_hits)}")

    # Wake ARP entries for anything we found but PC has not talked to yet.
    for ip in sorted(all_ips):
        if ip != local_ip:
            subprocess.call(
                ["ping", "-c", "1", "-W", "1", "-I", iface, ip],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )

    summary = f"house scan: {len(all_ips)} hosts ({', '.join(parts) or 'none'})"
    return all_ips, summary


def tailscale_peers() -> tuple[list[TailscalePeer], str]:
    if not shutil.which("tailscale"):
        return [], "tailscale CLI not installed"
    raw = run(["tailscale", "status", "--json"], timeout=10)
    if not raw:
        return [], "tailscale status failed"
    try:
        data = json.loads(raw)
    except json.JSONDecodeError:
        return [], "invalid tailscale JSON"
    peers: list[TailscalePeer] = []
    for peer in data.get("Peer", {}).values():
        ips = peer.get("TailscaleIPs") or []
        ip = ips[0] if ips else "?"
        peers.append(
            TailscalePeer(
                name=(peer.get("HostName") or peer.get("DNSName") or "?").strip(),
                ip=ip,
                online=bool(peer.get("Online")),
                last_seen=(peer.get("LastSeen") or "")[:19].replace("T", " "),
            )
        )
    peers.sort(key=lambda p: (not p.online, p.name.lower()))
    note = f"{sum(1 for p in peers if p.online)} online / {len(peers)} peers"
    self_ips = (data.get("Self") or {}).get("TailscaleIPs") or []
    if self_ips:
        note = f"this node {self_ips[0]} | {note}"
    return peers, note


def fritzbox_hosts(cfg: dict[str, Any]) -> tuple[list[RouterClient], str]:
    fb = cfg["router"]["fritzbox"]
    host = (fb.get("host") or cfg.get("router", {}).get("url") or router_admin_url(cfg) or "").rstrip("/")
    if not host:
        return [], "router host unknown — set router.url or check default route"
    user = fb.get("username", "admin")
    env_name = fb.get("password_env", "FRITZBOX_PASSWORD")
    password = os.environ.get(env_name, "")
    if not password:
        return [], f"set {env_name} for Fritz!Box login"
    try:
        with urlopen(f"{host}/login_sid.lua", timeout=5) as resp:
            sid_root = ET.fromstring(resp.read())
        sid = sid_root.findtext("SID") or ""
        challenge = sid_root.findtext("Challenge") or ""
        if sid == "0000000000000000" and challenge:
            response = f"{challenge}-{hashlib.md5(f'{challenge}-{password}'.encode()).hexdigest()}"
            with urlopen(f"{host}/login_sid.lua?username={user}&response={response}", timeout=5) as resp:
                sid = ET.fromstring(resp.read()).findtext("SID") or ""
        if not sid or sid == "0000000000000000":
            return [], "Fritz!Box login failed"
        soap = (
            '<?xml version="1.0" encoding="utf-8"?>'
            '<s:Envelope xmlns:s="http://schemas.xmlsoap.org/soap/envelope/">'
            "<s:Body><u:GetHostListInfo "
            'xmlns:u="urn:dslforum-org:service:Hosts:1"/></s:Body></s:Envelope>'
        )
        req = Request(
            f"{host}/upnp/control/hosts",
            data=soap.encode(),
            headers={
                "Content-Type": 'text/xml; charset="utf-8"',
                "SOAPAction": '"urn:dslforum-org:service:Hosts:1#GetHostListInfo"',
            },
            method="POST",
        )
        with urlopen(req, timeout=8) as resp:
            root = ET.fromstring(resp.read())
        clients: list[RouterClient] = []
        for elem in root.iter():
            if elem.tag.split("}")[-1] != "NewHostList":
                continue
            for child in elem:
                ip = mac = name = ""
                for fld in child:
                    ft = fld.tag.split("}")[-1]
                    if ft == "NewIPAddress":
                        ip = fld.text or ""
                    elif ft == "NewMACAddress":
                        mac = (fld.text or "").lower()
                    elif ft == "NewHostName":
                        name = fld.text or ""
                if mac:
                    clients.append(RouterClient(ip=ip, mac=mac, name=name or "?"))
        clients.sort(key=lambda c: ipaddress.ip_address(c.ip) if c.ip.count(".") == 3 else c.ip)
        return clients, f"Fritz!Box: {len(clients)} hosts"
    except (URLError, ET.ParseError, TimeoutError) as exc:
        return [], f"Fritz!Box error: {exc}"


def custom_router_hosts(cfg: dict[str, Any]) -> tuple[list[RouterClient], str]:
    script = expand_path(cfg["router"]["custom_script"])
    if not script.is_file():
        return [], f"missing script: {script}"
    try:
        proc = subprocess.run([str(script)], capture_output=True, text=True, timeout=15, check=False)
        raw = (proc.stdout or "").strip()
        items = json.loads(raw or "[]")
        clients = [
            RouterClient(
                ip=str(item.get("ip", "?")),
                mac=str(item.get("mac", "")).lower(),
                name=str(item.get("name", "?")),
            )
            for item in items
            if item.get("mac")
        ]
        clients.sort(key=lambda c: ipaddress.ip_address(c.ip) if c.ip.count(".") == 3 else c.ip)
        return clients, f"custom script: {len(clients)} hosts"
    except (json.JSONDecodeError, subprocess.TimeoutExpired) as exc:
        return [], f"custom script error: {exc}"


def router_clients(cfg: dict[str, Any]) -> tuple[list[RouterClient], str]:
    if not cfg["router"].get("enabled"):
        return [], "router.enabled: false"
    rtype = (cfg["router"].get("type") or "disabled").lower()
    if rtype == "disabled":
        return [], "router.type: disabled"
    if rtype == "fritzbox":
        return fritzbox_hosts(cfg)
    if rtype == "custom":
        return custom_router_hosts(cfg)
    return [], f"unknown router.type: {rtype}"


def ss_established() -> list[str]:
    cfg = load_config()
    known = load_known(expand_path(cfg["alerts"]["state_file"]))
    flows = outbound_flows(cfg, known, limit=10)
    return [f.connection for f in flows] or ["(no established sessions)"]


def _ss_process(line: str) -> str:
    m = re.search(r'users:\(\("([^"]+)"', line)
    if not m:
        return ""
    proc = m.group(1)
    return "Cursor" if proc == "MainThread" else proc


def _ss_process_pid(line: str) -> tuple[str, str]:
    m = re.search(r'users:\(\("([^"]+)",pid=(\d+)', line)
    if not m:
        proc = _ss_process(line)
        return proc, ""
    proc = m.group(1)
    proc = "Cursor" if proc == "MainThread" else proc
    return proc, m.group(2)


def _endpoint_host(addr: str) -> str:
    if addr.count(":") >= 2 and "]" in addr:
        m = re.match(r"^\[(.+)\](?::(\d+))?$", addr)
        if m:
            return m.group(1)
    host = addr.rsplit(":", 1)[0]
    if "%" in host:
        host = host.split("%", 1)[0]
    if host.startswith("[") and host.endswith("]"):
        host = host[1:-1]
    elif host.startswith("["):
        host = host[1:]
    return host


def _normalize_ip(ip: str) -> str:
    ip = ip.strip()
    if ip.startswith("[") and ip.endswith("]"):
        ip = ip[1:-1]
    lower = ip.lower()
    if lower.startswith("::ffff:"):
        return ip[7:]
    return ip


def _is_loopback_ip(ip: str) -> bool:
    if not ip or ip in ("*", "0.0.0.0"):
        return False
    ip = _normalize_ip(ip)
    if ip in ("127.0.0.1", "::1"):
        return True
    if ip.startswith("127."):
        return True
    try:
        return ipaddress.ip_address(ip).is_loopback
    except ValueError:
        return False


def _endpoint_port(addr: str) -> str:
    if addr.count(":") >= 2 and "[" in addr:
        m = re.search(r"\]:([0-9]+)$", addr)
        return m.group(1) if m else ""
    return addr.rsplit(":", 1)[-1] if ":" in addr else ""


def _compact_conn(local: str, remote: str, local_ip: str) -> str:
    """Shorten same-subnet IP in connection strings (e.g. .21:port)."""
    prefix = ""
    if local_ip and local_ip.count(".") == 3:
        prefix = local_ip.rsplit(".", 1)[0] + "."

    def short(addr: str) -> str:
        host = _endpoint_host(addr)
        port = _endpoint_port(addr)
        if prefix and host.startswith(prefix):
            host = "." + host[len(prefix) :]
        return f"{host}:{port}" if port else host

    return f"{short(local)} → {short(remote)}"


def _is_tailscale_ip(ip: str) -> bool:
    try:
        addr = ipaddress.ip_address(ip)
        return addr in ipaddress.ip_network("100.64.0.0/10")
    except ValueError:
        return False


def _simplify_hostname(host: str) -> str:
    host = host.strip().rstrip(".")
    if not host:
        return ""
    lower = host.lower()
    if "amazonaws.com" in lower:
        return "AWS EC2"
    if lower.endswith(".ts.net"):
        return host.split(".")[0]
    if lower.endswith(".local"):
        return host.split(".")[0]
    if lower.startswith("ec2-"):
        return "AWS EC2"
    return host[:22]


def _reverse_dns(ip: str, cache: dict[str, str]) -> str:
    if ip in cache:
        return cache[ip]
    name = ""
    if shutil.which("getent"):
        out = run(["getent", "hosts", ip], timeout=2)
        if out:
            name = _simplify_hostname(out.split()[1] if len(out.split()) > 1 else out)
    if not name:
        old = socket.getdefaulttimeout()
        try:
            socket.setdefaulttimeout(0.6)
            host, _, _ = socket.gethostbyaddr(ip)
            name = _simplify_hostname(host)
        except OSError:
            name = ""
        finally:
            socket.setdefaulttimeout(old)
    cache[ip] = name
    return name


def _ip_name_lookup(
    ip: str,
    *,
    known: dict[str, dict],
    router_clients: list[RouterClient],
    tailscale: list[TailscalePeer],
    gateway: str,
    dns_cache: dict[str, str],
) -> str:
    if ip == gateway:
        return "ZTE router"
    for _mac, entry in known.items():
        if str(entry.get("last_ip") or "") == ip:
            label = (entry.get("label") or entry.get("auto_guess") or entry.get("hostname") or "").strip()
            if label:
                return label.split(".")[0][:22]
    for client in router_clients:
        if client.ip == ip and client.name:
            return client.name[:22]
    for peer in tailscale:
        if peer.ip == ip and peer.name:
            return peer.name[:22]
    if _is_tailscale_ip(ip):
        rdns = _reverse_dns(ip, dns_cache)
        if rdns:
            return rdns
        return "Tailscale peer"
    if ip.startswith("192.168.") or ip.startswith("10.") or ip.startswith("172."):
        if shutil.which("avahi-resolve"):
            out = run(["avahi-resolve", "-a", ip], timeout=2)
            if out and "\t" in out:
                name = _simplify_hostname(out.split("\t", 1)[1])
                if name:
                    return name
    rdns = _reverse_dns(ip, dns_cache)
    return rdns or "(no reverse DNS)"


def _outbound_notes(
    *,
    local: str,
    remote_ip: str,
    remote_port: str,
    proc: str,
    gateway: str,
) -> str:
    parts: list[str] = []
    if proc:
        parts.append(proc)
    if _endpoint_port(local) == "68" and remote_port == "67":
        return "DHCP renew"
    if remote_ip == gateway:
        parts.append("gateway")
    if remote_port == "8009":
        parts.append("TV Cast")
    elif remote_port == "8001":
        parts.append("Samsung API")
    elif remote_port == "443":
        parts.append("HTTPS")
    elif remote_port == "8885":
        parts.append("custom port")
    if _is_tailscale_ip(_endpoint_host(local)) or _is_tailscale_ip(remote_ip):
        parts.append("Tailscale mesh")
    if remote_ip.startswith("192.168.") or remote_ip.startswith("10."):
        parts.append("LAN")
    if not parts:
        return "active session"
    return " · ".join(dict.fromkeys(parts))


def outbound_flows(
    cfg: dict[str, Any],
    known: dict[str, dict],
    router_clients: list[RouterClient] | None = None,
    tailscale: list[TailscalePeer] | None = None,
    *,
    limit: int = 8,
) -> list[OutboundFlow]:
    router_clients = router_clients or []
    tailscale = tailscale or []
    _, gateway, local_ip = default_route()
    dns_cache: dict[str, str] = {}
    flows: list[OutboundFlow] = []
    seen: set[str] = set()

    raw = run(["ss", "-H", "-tunp", "state", "established"], timeout=5)
    for line in raw.splitlines():
        cols = line.split()
        if len(cols) < 5:
            continue
        local, remote = cols[3], cols[4]
        remote_ip = _endpoint_host(remote)
        if remote_ip in ("127.0.0.1", "::1") or remote_ip.startswith("127."):
            continue
        proc = _ss_process(line)
        remote_port = _endpoint_port(remote)
        key = f"{remote_ip}:{remote_port}:{proc}"
        if key in seen:
            continue
        seen.add(key)

        name = _ip_name_lookup(
            remote_ip,
            known=known,
            router_clients=router_clients,
            tailscale=tailscale,
            gateway=gateway,
            dns_cache=dns_cache,
        )
        notes = _outbound_notes(
            local=local,
            remote_ip=remote_ip,
            remote_port=remote_port,
            proc=proc,
            gateway=gateway,
        )
        flows.append(
            OutboundFlow(
                connection=_compact_conn(local, remote, local_ip),
                name=name,
                notes=notes,
            )
        )
        if len(flows) >= limit:
            break

    return flows


def format_outbound_lines(flows: list[OutboundFlow], width: int, limit: int = 8) -> list[str]:
    flows = flows[:limit]
    if not flows:
        return ["(no established sessions)"]
    if width < 36:
        rows = ["◈ connection → name"]
        for f in flows:
            rows.append(f.connection[: width - 1])
            rows.append(f"  {f.name[:16]}  {f.notes}"[: width - 1])
        return rows

    conn_w = min(26, max(14, width * 2 // 5))
    name_w = min(16, max(8, width // 4))
    note_w = max(6, width - conn_w - name_w - 2)
    rows = [
        f"{'CONNECTION':<{conn_w}} {'NAME':<{name_w}} NOTES"[: width - 1],
        ("─" * min(width - 1, conn_w + name_w + 6))[: width - 1],
    ]
    for f in flows:
        row = f"{f.connection[:conn_w]:<{conn_w}} {f.name[:name_w]:<{name_w}} {f.notes[:note_w]}"
        rows.append(row[: width - 1])
    return rows


SERVICE_NAME_CACHE: dict[str, str] = {}


def _service_name_from_port(port: str) -> str:
    if port in SERVICE_NAME_CACHE:
        return SERVICE_NAME_CACHE[port]
    name = ""
    if shutil.which("getent"):
        out = run(["getent", "services", port], timeout=1)
        if out:
            name = out.split("/")[0].split()[0].strip()
    SERVICE_NAME_CACHE[port] = name
    return name


def _service_label(port: str, proc: str) -> str:
    if proc:
        return proc[:12]
    svc = _service_name_from_port(port)
    if svc:
        return svc[:12]
    return f":{port}"


@dataclass
class ListenerMatch:
    proc: str
    pid: str
    proto: str
    source: str = "ss"


_LISTENER_SCAN_CACHE: tuple[float, dict[str, ListenerMatch]] | None = None
_LISTENER_SCAN_TTL = 2.0


def _sudo_read_tools_available() -> bool:
    if not shutil.which("sudo"):
        return False
    probe = run(["sudo", "-n", "ss", "-H", "-tln"], timeout=3)
    return "password is required" not in probe.lower() and "a password is required" not in probe.lower()


def _parse_lsof_listen(out: str, proto: str) -> list[tuple[str, str, str]]:
    rows: list[tuple[str, str, str]] = []
    for line in out.splitlines():
        if not line or line.startswith("COMMAND"):
            continue
        parts = line.split()
        if len(parts) < 2:
            continue
        proc, pid = parts[0], parts[1]
        port_m = re.search(r":(\d+)(?:\s|\(|$)", line)
        if not port_m:
            continue
        rows.append((port_m.group(1), proc, pid))
    return rows


def _parse_fuser_port(out: str, err: str, proto: str) -> list[tuple[str, str, str]]:
    """Parse fuser output for a single port query."""
    text = f"{out}\n{err}"
    pids = re.findall(r"\b(\d+)\b", text)
    rows: list[tuple[str, str, str]] = []
    for pid in dict.fromkeys(pids):
        cmdline = Path(f"/proc/{pid}/comm")
        proc = cmdline.read_text().strip() if cmdline.is_file() else "?"
        rows.append(("", proc, pid))
    return rows


def _scan_listener_processes(*, use_sudo: bool = True) -> dict[str, ListenerMatch]:
    """Build port → process map from live OS data (no hardcoded port list)."""
    global _LISTENER_SCAN_CACHE
    now = time.time()
    if _LISTENER_SCAN_CACHE and now - _LISTENER_SCAN_CACHE[0] < _LISTENER_SCAN_TTL:
        return _LISTENER_SCAN_CACHE[1]

    rank = {"sudo_ss": 50, "user_ss": 30, "sudo_lsof": 40, "user_lsof": 20, "sudo_fuser": 35}
    matches: dict[str, ListenerMatch] = {}
    match_rank: dict[str, int] = {}

    def consider(port: str, proc: str, pid: str, proto: str, source: str) -> None:
        if not port or not proc:
            return
        r = rank.get(source, 0)
        if port not in matches or r > match_rank.get(port, 0):
            matches[port] = ListenerMatch(proc=proc, pid=pid, proto=proto, source=source)
            match_rank[port] = r

    ss_cmds: list[tuple[list[str], str, str]] = []
    if use_sudo and shutil.which("sudo"):
        ss_cmds.extend(
            [
                (["sudo", "-n", "ss", "-H", "-tlnp"], "tcp", "sudo_ss"),
                (["sudo", "-n", "ss", "-H", "-ulnp"], "udp", "sudo_ss"),
            ]
        )
    ss_cmds.extend(
        [
            (["ss", "-H", "-tlnp"], "tcp", "user_ss"),
            (["ss", "-H", "-ulnp"], "udp", "user_ss"),
        ]
    )
    for cmd, proto, source in ss_cmds:
        out = run(cmd, timeout=5)
        if "password is required" in out.lower():
            continue
        for line in out.splitlines():
            cols = line.split()
            if len(cols) < 4:
                continue
            port = _endpoint_port(cols[3])
            proc, pid = _ss_process_pid(line)
            consider(port, proc, pid, proto, source)

    lsof = shutil.which("lsof")
    if lsof:
        lsof_cmds: list[tuple[list[str], str, str]] = []
        if use_sudo and shutil.which("sudo"):
            lsof_cmds.extend(
                [
                    (["sudo", "-n", lsof, "-iTCP", "-sTCP:LISTEN", "-P", "-n"], "tcp", "sudo_lsof"),
                    (["sudo", "-n", lsof, "-iUDP", "-P", "-n"], "udp", "sudo_lsof"),
                ]
            )
        lsof_cmds.extend(
            [
                ([lsof, "-iTCP", "-sTCP:LISTEN", "-P", "-n"], "tcp", "user_lsof"),
                ([lsof, "-iUDP", "-P", "-n"], "udp", "user_lsof"),
            ]
        )
        for cmd, proto, source in lsof_cmds:
            out = run(cmd, timeout=8)
            if "password is required" in out.lower():
                continue
            for port, proc, pid in _parse_lsof_listen(out, proto):
                consider(port, proc, pid, proto, source)

    _LISTENER_SCAN_CACHE = (now, matches)
    return matches


def _resolve_listener(port: str, listener_map: dict[str, ListenerMatch] | None = None) -> tuple[str, str, str, str]:
    """Return (process, pid, proto, detail). Fully dynamic — no port name database."""
    listener_map = listener_map or _scan_listener_processes()
    hit = listener_map.get(port)
    if hit:
        return hit.proc, hit.pid, hit.proto, ""

    # Last resort for a single unknown port: fuser (still dynamic)
    if shutil.which("fuser"):
        for proto in ("tcp", "udp"):
            for cmd_prefix in (["sudo", "-n", "fuser"], ["fuser"]):
                if cmd_prefix[0] == "sudo" and not shutil.which("sudo"):
                    continue
                cmd = [*cmd_prefix, f"{port}/{proto}"]
                try:
                    proc = subprocess.run(
                        cmd, capture_output=True, text=True, timeout=4, check=False
                    )
                except (subprocess.TimeoutExpired, FileNotFoundError):
                    continue
                err = (proc.stderr or proc.stdout or "").strip()
                if "password is required" in err.lower() or not err:
                    continue
                pid_m = re.search(r"\b(\d+)\b", err)
                if pid_m:
                    pid = pid_m.group(1)
                    comm = Path(f"/proc/{pid}/comm")
                    name = comm.read_text().strip() if comm.is_file() else "?"
                    return name, pid, proto, ""
    return "", "", "", ""


def dig_listener(port: str, listener_map: dict[str, ListenerMatch] | None = None) -> dict[str, Any]:
    """Deep lookup for one port — used by CLI and detail view."""
    proc, pid, proto, detail = _resolve_listener(port, listener_map)
    lines: list[str] = []
    for cmd in (
        ["ss", "-H", "-tlnp", f"sport = :{port}"],
        ["ss", "-H", "-ulnp", f"sport = :{port}"],
        ["sudo", "-n", "ss", "-H", "-tulnp", f"sport = :{port}"],
    ):
        if cmd[0] == "sudo" and not shutil.which("sudo"):
            continue
        out = run(cmd, timeout=5)
        if out and "password is required" not in out.lower():
            lines.extend(out.splitlines())
    sudo_ok = _sudo_read_tools_available()
    unresolved = not proc and not detail
    return {
        "port": port,
        "process": proc or detail or ("unidentified" if unresolved else "?"),
        "pid": pid,
        "proto": proto,
        "detail": detail,
        "ss_lines": lines,
        "sudo_ok": sudo_ok,
        "tip": (
            "Run: netwatch --setup  (enables passwordless sudo ss/lsof for root-owned services)"
            if unresolved and not sudo_ok
            else ""
        ),
    }


def _ephemeral_port_range() -> tuple[int, int]:
    path = Path("/proc/sys/net/ipv4/ip_local_port_range")
    try:
        parts = path.read_text().split()
        if len(parts) >= 2:
            return int(parts[0]), int(parts[1])
    except OSError:
        pass
    return 32768, 60999


def _listening_sockets() -> dict[str, list[str]]:
    ports: dict[str, list[str]] = {}
    for flag in ("-tln", "-uln"):
        for line in run(["ss", "-H", flag], timeout=5).splitlines():
            cols = line.split()
            if len(cols) < 4:
                continue
            host = _endpoint_host(cols[3])
            port = _endpoint_port(cols[3])
            if not port:
                continue
            ports.setdefault(port, [])
            if host not in ports[port]:
                ports[port].append(host)
    return ports


def trusted_peers_path(cfg: dict[str, Any]) -> Path:
    return expand_path(
        cfg.get("host_exposure", {}).get("trusted_peers_file", str(TRUSTED_PEERS_PATH))
    )


def load_trusted_peers(cfg: dict[str, Any]) -> dict[str, dict]:
    path = trusted_peers_path(cfg)
    if not path.is_file():
        return {}
    try:
        data = json.loads(path.read_text())
        return data if isinstance(data, dict) else {}
    except (json.JSONDecodeError, OSError):
        return {}


def save_trusted_peers(cfg: dict[str, Any], peers: dict[str, dict]) -> None:
    path = trusted_peers_path(cfg)
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(peers, indent=2, sort_keys=True) + "\n")


def is_trusted_inbound_ip(cfg: dict[str, Any], ip: str, peers: dict[str, dict] | None = None) -> bool:
    if ip in (cfg.get("host_exposure", {}).get("trusted_ips") or []):
        return True
    peers = peers if peers is not None else load_trusted_peers(cfg)
    return ip in peers


def trust_inbound_ips(cfg: dict[str, Any], ips: list[str]) -> int:
    peers = load_trusted_peers(cfg)
    now = time.strftime("%Y-%m-%dT%H:%M:%S")
    count = 0
    for ip in ips:
        ip = ip.strip()
        if not ip or is_trusted_inbound_ip(cfg, ip, peers):
            continue
        entry = peers.get(ip, {})
        if not isinstance(entry, dict):
            entry = {"label": str(entry)}
        entry["ack_at"] = now
        peers[ip] = entry
        count += 1
    if count:
        save_trusted_peers(cfg, peers)
    return count


def inbound_flows(
    cfg: dict[str, Any],
    known: dict[str, dict],
    router_clients: list[RouterClient] | None = None,
    tailscale: list[TailscalePeer] | None = None,
    *,
    limit: int = 8,
) -> tuple[list[InboundFlow], list[str]]:
    he = cfg.get("host_exposure", {})
    if not he.get("enabled", True) or not he.get("monitor_inbound", True):
        return [], []

    router_clients = router_clients or []
    tailscale = tailscale or []
    listen = _listening_sockets()
    eph_lo, eph_hi = _ephemeral_port_range()
    trusted = load_trusted_peers(cfg)
    _, gateway, local_ip = default_route()
    dns_cache: dict[str, str] = {}
    flows: list[InboundFlow] = []
    new_ips: list[str] = []
    seen: set[str] = set()

    for line in run(["ss", "-H", "-tunp", "state", "established"], timeout=5).splitlines():
        cols = line.split()
        if len(cols) < 5:
            continue
        local, remote = cols[3], cols[4]
        local_ip_ep, local_port = _endpoint_host(local), _endpoint_port(local)
        remote_ip, remote_port = _endpoint_host(remote), _endpoint_port(remote)
        if _is_loopback_ip(remote_ip) or _is_loopback_ip(local_ip_ep):
            continue
        if local_ip and _normalize_ip(remote_ip) == _normalize_ip(local_ip):
            continue
        if not local_port or local_port not in listen:
            continue
        bind_addrs = listen.get(local_port, [])
        if bind_addrs and all(_is_loopback_ip(a) or a in ("127.0.0.1", "[::1]") for a in bind_addrs):
            continue
        try:
            rp = int(remote_port)
        except ValueError:
            continue
        if not (eph_lo <= rp <= eph_hi):
            continue

        proc = _ss_process(line)
        key = f"{remote_ip}:{local_port}:{proc}"
        if key in seen:
            continue
        seen.add(key)

        name = _ip_name_lookup(
            remote_ip,
            known=known,
            router_clients=router_clients,
            tailscale=tailscale,
            gateway=gateway,
            dns_cache=dns_cache,
        )
        service = _service_label(local_port, proc)
        is_new = not is_trusted_inbound_ip(cfg, remote_ip, trusted)
        if is_new and remote_ip not in new_ips:
            new_ips.append(remote_ip)

        flows.append(
            InboundFlow(
                connection=_compact_conn(remote, local, local_ip),
                remote_ip=remote_ip,
                name=name,
                service=service,
                proc=proc,
                is_new=is_new,
            )
        )
        if len(flows) >= limit:
            break

    return flows, new_ips


def format_inbound_lines(flows: list[InboundFlow], width: int, limit: int = 6) -> list[str]:
    flows = flows[:limit]
    if not flows:
        return ["(no inbound sessions)"]
    if width < 34:
        rows: list[str] = []
        for f in flows:
            tag = "▸NEW" if f.is_new else ""
            rows.append(f"{f.remote_ip[:14]} → :{f.service}{tag}"[: width - 1])
        return rows

    peer_w = min(18, max(10, width // 3))
    svc_w = min(10, max(6, width // 5))
    rows = [f"{'REMOTE':<{peer_w}} {'SVC':<{svc_w}} PROC"[: width - 1]]
    for f in flows:
        tag = "*" if f.is_new else " "
        row = f"{tag}{f.name[:peer_w - 1]:<{peer_w - 1}} {f.service[:svc_w]:<{svc_w}} {f.proc[: max(4, width - peer_w - svc_w - 2)]}"
        rows.append(row[: width - 1])
    return rows


def network_path_links(cfg: dict[str, Any]) -> list[BridgeLink]:
    he = cfg.get("host_exposure", {})
    if not he.get("enabled", True) or not he.get("monitor_bridges", True):
        return []

    links: list[BridgeLink] = []
    seen: set[str] = set()

    def add(name: str, state: str, note: str) -> None:
        if name in seen:
            return
        seen.add(name)
        links.append(BridgeLink(name=name, state=state, note=note))

    for line in run(["ip", "-br", "link", "show", "type", "bridge"]).splitlines():
        parts = line.split(maxsplit=3)
        if parts:
            add(parts[0], parts[1] if len(parts) > 1 else "?", "L2 bridge — LAN segments meet here")

    for itype, note in (
        ("tun", "VPN tunnel — remote peers may reach this host"),
        ("wireguard", "WireGuard — mesh / remote access path"),
    ):
        for line in run(["ip", "-br", "link", "show", "type", itype]).splitlines():
            parts = line.split(maxsplit=3)
            if parts:
                add(parts[0], parts[1] if len(parts) > 1 else "?", note)

    for line in run(["ip", "-br", "link"]).splitlines():
        parts = line.split(maxsplit=3)
        if not parts:
            continue
        name = parts[0].split("@", 1)[0]
        state = parts[1] if len(parts) > 1 else "?"
        if name in seen:
            continue
        if name in ("docker0", "virbr0", "tailscale0", "cni0") or name.startswith(("br-", "veth")):
            note = "virtual path — other devices can route through this box"
            if name == "tailscale0":
                note = "Tailscale mesh — trusted peers can reach services"
            elif name == "docker0":
                note = "Docker bridge — container network gateway"
            add(name, state, note)

    return links[:8]


def exposed_listeners(
    cfg: dict[str, Any],
    *,
    limit: int = 6,
    listener_map: dict[str, ListenerMatch] | None = None,
) -> list[ExposedListener]:
    he = cfg.get("host_exposure", {})
    if not he.get("enabled", True) or not he.get("monitor_listeners", True):
        return []

    _, _, local_ip = default_route()
    trusted_ports = {str(p) for p in (he.get("trusted_ports") or [])}
    rows: list[ExposedListener] = []
    seen: set[str] = set()
    listener_map = listener_map or _scan_listener_processes(
        use_sudo=he.get("resolve_with_sudo", True)
    )

    for flag in ("-tln", "-uln"):
        for line in run(["ss", "-H", flag]).splitlines():
            cols = line.split()
            if len(cols) < 4:
                continue
            bind = cols[3]
            host = _endpoint_host(bind)
            port = _endpoint_port(bind)
            if not port or port in seen:
                continue
            if _is_loopback_ip(host):
                continue
            if host not in ("0.0.0.0", "*", "[::]", "::", local_ip) and not host.startswith("192.168."):
                if not host.startswith("10.") and not host.startswith("172."):
                    continue
            seen.add(port)
            proc, pid, proto, detail = _resolve_listener(port, listener_map)
            if not proc and not detail:
                detail = "unidentified"
            if port in trusted_ports:
                risk = "ok"
            elif host in ("0.0.0.0", "*", "[::]", "::"):
                risk = "alert"
            else:
                risk = "warn"
            rows.append(
                ExposedListener(
                    bind=bind[:22],
                    port=port,
                    proc=proc,
                    risk=risk,
                    pid=pid,
                    proto=proto,
                    detail=detail,
                )
            )
            if len(rows) >= limit:
                return rows
    return rows


def active_login_sessions() -> list[str]:
    rows: list[str] = []
    for line in run(["who"]).splitlines():
        line = line.strip()
        if line:
            rows.append(line[:72])
    if not rows and shutil.which("users"):
        out = run(["users"]).strip()
        if out:
            rows.append(f"users: {out[:64]}")
    return rows[:5]


def collect_host_exposure(
    cfg: dict[str, Any],
    known: dict[str, dict],
    router_clients: list[RouterClient],
    tailscale: list[TailscalePeer],
) -> tuple[list[InboundFlow], list[str], list[BridgeLink], list[ExposedListener], list[str]]:
    he = cfg.get("host_exposure", {})
    listener_map = _scan_listener_processes(use_sudo=he.get("resolve_with_sudo", True))
    inbound, new_inbound = inbound_flows(
        cfg, known, router_clients, tailscale, limit=12
    )
    bridges = network_path_links(cfg)
    exposed = exposed_listeners(cfg, limit=8, listener_map=listener_map)
    logins = active_login_sessions()
    return inbound, new_inbound, bridges, exposed, logins


def listener_resolve_status(cfg: dict[str, Any]) -> str:
    """Short status when root-owned listeners cannot be named yet."""
    if not _sudo_read_tools_available():
        he = cfg.get("host_exposure", {})
        listener_map = _scan_listener_processes(use_sudo=False)
        exposed = exposed_listeners(cfg, limit=16, listener_map=listener_map)
        if any(format_listener_label(e) == "unidentified" for e in exposed):
            return "run netwatch --setup once for full process names"
    return ""


def ss_listening() -> list[str]:
    rows: list[str] = []
    for line in run(["ss", "-H", "-tln"]).splitlines()[:10]:
        cols = line.split()
        if len(cols) >= 4:
            rows.append(cols[3])
