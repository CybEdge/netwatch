                safe_addstr(stdscr, i + 2, 2, rows[idx], row_attrs[idx], w - 3)
            safe_addstr(stdscr, h - 3, 0, ("─" * max(0, w - 1))[: w - 1], cp(CP_MAGENTA, dim=True))
            safe_addstr(stdscr, h - 2, 2, ui_status.current()[: w - 4], cp(CP_YELLOW, dim=True))
            stdscr.refresh()
            ch = stdscr.getch()
            if ch == -1:
                continue
            if ch in (ord("q"), ord("Q"), 27):
                cyber_screen_exit(stdscr)
                return ""
            if ch in (curses.KEY_UP, ord("k")) and offset > 0:
                offset -= 1
            if ch in (curses.KEY_DOWN, ord("j")) and offset + visible < len(rows):
                offset += 1
            if ch in (ord("r"), ord("R")):
                devices = parse_neigh(iface) if iface else []
                dash.devices = devices
                dash = reload_labels(cfg, iface, dash)
                ui_status.flash("list refreshed (no network probe)")
            if ch in (ord("n"), ord("N")):
                dash = run_with_cyber_loader(
                    stdscr,
                    "SCAN",
                    collect_state,
                    cfg,
                    iface,
                    False,
                    force_identify=True,
                    network=True,
                )
                ui_status.flash("probed hostnames, vendors, and unknown devices")
            if ch in (ord("m"), ord("M")):
                n = merge_manual_labels(cfg)
                dash = reload_labels(cfg, iface, dash)
                ui_status.flash(f"imported {n} label(s) from router-manual.json")
            if ch in (ord("l"), ord("L")):
                num = prompt_line(stdscr, h - 3, "▸ row # to label: ", w)
                if not num.isdigit():
                    ui_status.flash("invalid row number")
                    continue
                idx = int(num) - 1
                if idx < 0 or idx >= len(dash.devices):
                    ui_status.flash("row out of range")
                    continue
                dev = dash.devices[idx]
                label = prompt_line(stdscr, h - 3, f"▸ label for {dev.ip} ({dev.guess}): ", w)
                if label:
                    set_device_label(cfg, dev.mac, label)
                    dash = reload_labels(cfg, iface, dash)
                    ui_status.flash(f"saved label '{label}'")
            if ch in (ord("b"), ord("B")):
                ok_gate, gate_msg = gate_capability(stdscr, cfg, check_countermeasures_gap(cfg))
                if not ok_gate:
                    ui_status.flash(
                        gate_msg if gate_msg != "cancelled" else "block cancelled"
                    )
                    continue
                if gate_msg:
                    ui_status.flash(gate_msg)
                num = prompt_line(stdscr, h - 3, "▸ row # to block: ", w)
                if not num.isdigit():
                    ui_status.flash("invalid row number")
                    continue
                idx = int(num) - 1
                if idx < 0 or idx >= len(dash.devices):
                    ui_status.flash("row out of range")
                    continue
                dev = dash.devices[idx]
                reason = prompt_line(stdscr, h - 3, f"▸ reason to block {dev.ip}: ", w)
                ok, msg = block_device(cfg, dev.mac, dev.ip, label=dev.label or dev.guess, reason=reason)
                dash = collect_state(cfg, iface, network=False)
                ui_status.flash(msg if ok else f"block failed: {msg}")
            if ch in (ord("x"), ord("X")):
                num = prompt_line(stdscr, h - 3, "▸ row # to unblock: ", w)
                if not num.isdigit():
                    ui_status.flash("invalid row number")
                    continue
                idx = int(num) - 1
                if idx < 0 or idx >= len(dash.devices):
                    ui_status.flash("row out of range")
                    continue
                dev = dash.devices[idx]
                ok, msg = unblock_device(cfg, dev.mac)
                dash = collect_state(cfg, iface, network=False)
                ui_status.flash(msg if ok else f"unblock failed: {msg}")
    finally:
        stdscr.timeout(IDLE_TIMEOUT_MS)


def show_host_exposure(stdscr, cfg: dict[str, Any], iface: str) -> str:
    cyber_screen_enter(stdscr, "HOST")
    cfg = load_config()
    ok, msg = gate_capability(stdscr, cfg, check_host_exposure_gap(cfg))
    if not ok:
        cyber_screen_exit(stdscr)
        return msg if msg != "cancelled" else ""
    ttl = status_flash_seconds(cfg)
    legend = "T trust · d port dig · r refresh · q back"
    ui_status = FlashStatus(legend, ttl=ttl)
    stdscr.timeout(IDLE_TIMEOUT_MS)
    try:
        while True:
            cfg = load_config()
            dash = collect_state(cfg, iface, network=False)
            stdscr.erase()
            h, w = stdscr.getmaxyx()
            footer = ui_status.current()
            draw_cyber_hud_bar(stdscr, 0, w, " HOST EXPOSURE // sessions reaching THIS node ", footer, pair=CP_ALERT)
            row = 2
            half = max(24, (w - 3) // 2)

            draw_cyber_panel(stdscr, row, 0, h - row - 2, half, "INBOUND :: remote → you", pair=CP_ALERT)
            lines: list[str] = []
            attrs: list[int] = []
            for f in dash.inbound:
                tag = "▸UNTRUSTED" if f.is_new else "trusted"
                lines.append(f"{f.remote_ip:<16} → {f.service:<8} {f.proc or '?'}")
                lines.append(f"  {f.name[:28]}  {tag}")
                attrs.extend([cp(CP_ALERT, bold=True) if f.is_new else cp(CP_GREEN), cp(CP_WHITE, dim=True)])
            if not lines:
                lines = ["(no remote sessions to listening ports)"]
            put_lines(stdscr, row + 1, 2, half - 4, lines, cp(CP_WHITE, dim=True), line_attrs=attrs or None)

            draw_cyber_panel(stdscr, row, half + 1, h - row - 2, w - half - 2, "PATHS :: bridges/tunnels", pair=CP_MAGENTA)
            path_lines: list[str] = []
            for b in dash.bridges:
                path_lines.append(f"◈ {b.name} ({b.state})")
                path_lines.append(f"  {b.note[: half - 6]}")
            if dash.login_sessions:
                path_lines.append("── logins (who) ──")
                path_lines.extend(dash.login_sessions)
            if dash.exposed:
                path_lines.append("── LAN listeners ──")
                for e in dash.exposed:
                    mark = "!" if e.risk == "alert" else "·"
                    label = format_listener_label(e)
                    extra = f" {e.proto}" if e.proto else ""
                    path_lines.append(f"{mark} :{e.port}{extra} {label}")
                path_lines.append("  d + port# to dig (e.g. d11434)")
            put_lines(
                stdscr,
                row + 1,
                half + 3,
                w - half - 5,
                path_lines or ["(no bridges/tunnels detected)"],
                cp(CP_MAGENTA, dim=True),
            )

            draw_cyber_footer(stdscr, h - 1, w, footer)
            stdscr.refresh()
            ch = stdscr.getch()
            if ch == -1:
                continue
            if ch in (ord("q"), ord("Q"), 27):
                cyber_screen_exit(stdscr)
                return ""
            if ch in (ord("t"), ord("T")):
                n = trust_inbound_ips(cfg, dash.new_inbound or [f.remote_ip for f in dash.inbound if f.is_new])
                ui_status.flash(f"trusted {n} inbound peer(s)" if n else "no new peers to trust")
            if ch in (ord("r"), ord("R")):
                dash = collect_state(cfg, iface, network=False)
                ui_status.flash(f"refresh {time.strftime('%H:%M:%S')}")
            if ch in (ord("d"), ord("D")):
                port = prompt_line(stdscr, h - 3, "▸ port to dig (e.g. 11434): ", w)
                if port.isdigit():
                    info = dig_listener(port)
                    ui_status.flash(
                        f":{port} → {info['process']}"
                        + (f" pid {info['pid']}" if info["pid"] else "")
                        + (f" [{info['proto']}]" if info["proto"] else "")
                    )
                else:
                    ui_status.flash("invalid port")
    finally:
        stdscr.timeout(IDLE_TIMEOUT_MS)


def show_help(stdscr, cfg: dict[str, Any]) -> None:
    cyber_screen_enter(stdscr, "HELP")
    lines = help_lines(cfg)
    offset = 0
    while True:
        stdscr.erase()
        h, w = stdscr.getmaxyx()
        draw_cyber_hud_bar(
            stdscr,
            0,
            w,
            " NETWATCH // DATASHEET // NEURAL OPS MANUAL ",
            "▸ q·close ",
            pair=CP_CYAN,
        )
        safe_addstr(stdscr, 1, 0, ("═" * max(0, w - 1))[: w - 1], cp(CP_CYAN, dim=True))
        visible = h - 3
        for i in range(visible):
            idx = offset + i
            if idx >= len(lines):
                break
            safe_addstr(stdscr, i + 2, 2, lines[idx], help_line_attr(lines[idx]), w - 3)
        scroll_hint = (
            f" ◈ scroll ↑↓/jk  "
            f"{offset + 1}-{min(offset + visible, len(lines))}/{len(lines)}  "
            f"space/enter/q·exit "
        )
        safe_addstr(stdscr, h - 1, 0, scroll_hint[: w - 1], cp(CP_YELLOW, dim=True))
