def expand_path(value: str) -> Path:
    return Path(os.path.expanduser(value))


def load_config() -> dict[str, Any]:
    cfg = json.loads(json.dumps(DEFAULT_CONFIG))
    if CONFIG_PATH.is_file() and yaml:
        loaded = yaml.safe_load(CONFIG_PATH.read_text()) or {}
        for section, values in loaded.items():
            if isinstance(values, dict) and isinstance(cfg.get(section), dict):
                cfg[section].update(values)
            else:
                cfg[section] = values
    resolve_router_hosts(cfg)
    return cfg


def gateway_http_url(gateway: str | None = None) -> str:
    """Router admin base URL from default gateway (no hardcoded LAN)."""
    if gateway is None:
        _, gateway, _ = default_route()
    gw = (gateway or "").strip()
    if not gw:
        return ""
    if gw.startswith("http://") or gw.startswith("https://"):
        return gw.rstrip("/")
    return f"http://{gw}"


def resolve_router_hosts(cfg: dict[str, Any]) -> None:
    """Fill empty router host fields from the live default gateway."""
    gw_url = gateway_http_url()
    if not gw_url:
        return
    router = cfg.setdefault("router", {})
    if not str(router.get("url") or "").strip():
        router["url"] = gw_url
    fb = router.setdefault("fritzbox", {})
    if not str(fb.get("host") or "").strip():
        fb["host"] = gw_url
    rb = cfg.get("countermeasures", {}).get("router_block") or {}
    if isinstance(rb, dict) and not str(rb.get("host") or "").strip():
        cfg.setdefault("countermeasures", {}).setdefault("router_block", {})["host"] = gw_url


def router_admin_url(cfg: dict[str, Any]) -> str:
    """Best-effort router UI URL for display and API calls."""
    router = cfg.get("router") or {}
    rb = (cfg.get("countermeasures") or {}).get("router_block") or {}
    for candidate in (
        rb.get("host"),
        router.get("url"),
        (router.get("fritzbox") or {}).get("host"),
    ):
        text = str(candidate or "").strip()
        if text:
            return text.rstrip("/")
    return gateway_http_url()


