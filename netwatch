    out = run(
        ["journalctl", "_SYSTEMD_UNIT=sshd.service", "PRIORITY=err", "-n", "5", "--no-pager", "-o", "short-iso"],
        timeout=5,
    )
    lines = [ln for ln in out.splitlines() if ln.strip()]
