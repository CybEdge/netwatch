    except ValueError:
        return True
    return (time.time() - last_ts) >= max(1, repeat_hours) * 3600


def send_desktop_notify(title: str, body: str) -> bool:
    if not shutil.which("notify-send"):
        return False
    try:
        subprocess.run(
            ["notify-send", "-u", "critical", "-a", "netwatch", title, body],
            check=False,
            timeout=5,
        )
        return True
    except (subprocess.TimeoutExpired, OSError):
        return False


def send_alert_email(cfg: dict[str, Any], subject: str, body: str) -> tuple[bool, str]:
    ec = cfg.get("notifications", {}).get("email", {})
    if not ec.get("enabled"):
        return False, "email disabled"
    to_addr = str(ec.get("to") or "").strip()
    if not to_addr:
        return False, "email.to not set in config"
    user = os.environ.get(str(ec.get("username_env") or "NETWATCH_SMTP_USER"), "")
    password = os.environ.get(str(ec.get("password_env") or "NETWATCH_SMTP_PASS"), "")
    if not user or not password:
        return False, "set SMTP env vars (NETWATCH_SMTP_USER / NETWATCH_SMTP_PASS)"

    msg = EmailMessage()
    msg["Subject"] = subject
    msg["From"] = str(ec.get("from") or user)
    msg["To"] = to_addr
    msg.set_content(body)

    host = str(ec.get("smtp_host") or "localhost")
    port = int(ec.get("smtp_port") or 587)
    use_tls = ec.get("use_tls", True)
    try:
        with smtplib.SMTP(host, port, timeout=20) as smtp:
            if use_tls:
                smtp.starttls()
            smtp.login(user, password)
            smtp.send_message(msg)
        return True, f"email sent to {to_addr}"
    except (OSError, smtplib.SMTPException) as exc:
        return False, str(exc)[:200]


def format_unknown_alert(devices: list[LanDevice], known: dict[str, dict]) -> str:
    lines = ["Unknown device(s) on your LAN:", ""]
    for dev in devices:
        name = device_display_name(dev.mac, known)
        rnd = " [random MAC]" if is_random_mac(dev.mac) else ""
        lines.append(f"  • {dev.ip}  {dev.mac}  {name}{rnd}  ({dev.state})")
    lines.extend(["", "Run: netwatch → press i to identify, b to block.", "Ack trusted: press a on dashboard."])
    return "\n".join(lines)


def run_security_check(cfg: dict[str, Any], *, scan: bool = True) -> dict[str, Any]:
    iface, gateway, local = default_route()
    result: dict[str, Any] = {
        "ok": True,
        "iface": iface,
        "local": local,
        "gateway": gateway,
        "unknown": [],
        "blocked_online": [],
        "messages": [],
    }
    if not iface or not local:
        result["ok"] = False
        result["error"] = "no default route"
        return result

    if scan:
        _, summary = house_scan(cfg, iface, local)
        result["scan_summary"] = summary
        time.sleep(0.2)

    devices = parse_neigh(iface)
    known_path = expand_path(cfg["alerts"]["state_file"])
    known = load_known(known_path)
    blocked = update_blocked_ping_status(cfg, iface)

    unknown: list[LanDevice] = []
    for dev in devices:
        if device_needs_attention(dev, known, cfg):
            enrich_devices([dev], known, [], cfg, force_refresh=False, network=False)
            unknown.append(dev)
        if is_blocked_mac(cfg, dev.mac):
            dev.notes = "BLOCKED"

    blocked_online = [
        BlockedEntry(
            mac=mac,
            last_ip=str(entry.get("last_ip") or "?"),
            label=str(entry.get("label") or mac),
            online=bool(entry.get("online")),
        )
        for mac, entry in blocked.items()
        if entry.get("online")
    ]

    result["unknown"] = unknown
    result["blocked_online"] = blocked_online

    if cfg.get("host_exposure", {}).get("enabled", True):
        known_for_host = load_known(expand_path(cfg["alerts"]["state_file"]))
        rclients, _ = router_clients(cfg)
        ts_peers: list[TailscalePeer] = []
        if cfg["tailscale"].get("enabled", True):
            ts_peers, _ = tailscale_peers()
        inbound, new_inbound, bridges, exposed, logins = collect_host_exposure(
            cfg, known_for_host, rclients, ts_peers
        )
        result["inbound"] = inbound
        result["new_inbound"] = new_inbound
        result["bridges"] = bridges
        result["exposed"] = exposed
        result["login_sessions"] = logins

    return result


def deliver_unknown_alerts(cfg: dict[str, Any], unknown: list[LanDevice]) -> list[str]:
    """Notify only — never quarantine. Blocking requires manual b in identify."""
    if not cfg.get("notifications", {}).get("enabled", True) or not unknown:
        return []

    known = load_known(expand_path(cfg["alerts"]["state_file"]))
    repeat_hours = int(cfg.get("notifications", {}).get("repeat_hours") or 24)
    state = load_alert_state()
    notify_list = [d for d in unknown if should_notify_mac(d.mac, state, repeat_hours)]
    if not notify_list:
        return ["alert suppressed (already notified recently)"]

    body = format_unknown_alert(notify_list, known)
    subject = f"[netwatch] {len(notify_list)} unknown device(s) on LAN"
    messages: list[str] = []

    if cfg.get("notifications", {}).get("desktop", {}).get("enabled", True):
        if send_desktop_notify(subject, body.replace("\n", " · ")[:240]):
            messages.append("desktop notification sent")

    ok, msg = send_alert_email(cfg, subject, body)
    if ok:
        messages.append(msg)
    elif cfg.get("notifications", {}).get("email", {}).get("enabled"):
        messages.append(f"email failed: {msg}")

    now = time.strftime("%Y-%m-%dT%H:%M:%S")
    for dev in notify_list:
        state.setdefault("notified_macs", {})[dev.mac.lower()] = now
    save_alert_state(state)
    return messages or ["alert recorded"]


def format_inbound_alert(flows: list[InboundFlow]) -> str:
    lines = ["Remote session(s) reaching THIS computer:", ""]
    for f in flows:
        tag = " [untrusted]" if f.is_new else ""
        lines.append(f"  • {f.remote_ip} → port {f.service} ({f.proc or '?'})  {f.name}{tag}")
    lines.extend(
        [
            "",
            "Run: netwatch → press e for host exposure detail.",
            "Trust known peers: press T on dashboard.",
            "This is NOT auto-block — verify SSH/RDP/tunnel access.",
        ]
    )
    return "\n".join(lines)


def deliver_inbound_alerts(cfg: dict[str, Any], flows: list[InboundFlow]) -> list[str]:
    he = cfg.get("host_exposure", {})
    if not he.get("alert_inbound", True) or not flows:
        return []
    if not cfg.get("notifications", {}).get("enabled", True):
        return []

    untrusted = [f for f in flows if f.is_new]
    if not untrusted:
        return []

    repeat_hours = int(cfg.get("notifications", {}).get("repeat_hours") or 24)
    state = load_alert_state()
    notify_ips = [
        f.remote_ip
        for f in untrusted
        if should_notify_mac(f"inbound:{f.remote_ip}", state, repeat_hours)
    ]
    if not notify_ips:
        return ["inbound alert suppressed (already notified recently)"]

    notify_flows = [f for f in untrusted if f.remote_ip in notify_ips]
    body = format_inbound_alert(notify_flows)
    subject = f"[netwatch] {len(notify_flows)} inbound session(s) on your PC"
    messages: list[str] = []

    if cfg.get("notifications", {}).get("desktop", {}).get("enabled", True):
        if send_desktop_notify(subject, body.replace("\n", " · ")[:240]):
            messages.append("desktop inbound notification sent")

    ok, msg = send_alert_email(cfg, subject, body)
    if ok:
        messages.append(msg)
    elif cfg.get("notifications", {}).get("email", {}).get("enabled"):
        messages.append(f"inbound email failed: {msg}")

    now = time.strftime("%Y-%m-%dT%H:%M:%S")
    for ip in notify_ips:
        state.setdefault("notified_macs", {})[f"inbound:{ip}"] = now
    save_alert_state(state)
    return messages or ["inbound alert recorded"]


def cli_dig_listeners(cfg: dict[str, Any] | None = None, port: str | None = None) -> int:
    cfg = cfg or load_config()
    he = cfg.get("host_exposure", {})
    listener_map = _scan_listener_processes(use_sudo=he.get("resolve_with_sudo", True))
    if port:
        info = dig_listener(port, listener_map)
        print(f"Port {port}")
        print(f"  process: {info['process']}")
        if info["pid"]:
            print(f"  pid:     {info['pid']}")
        if info["proto"]:
            print(f"  proto:   {info['proto']}")
        if info["ss_lines"]:
            print("  ss:")
            for line in info["ss_lines"][:6]:
                print(f"    {line}")
        if info.get("tip"):
            print(f"  tip: {info['tip']}")
        return 0

    exposed = exposed_listeners(cfg, limit=32, listener_map=listener_map)
    if not exposed:
        print("No LAN-wide listeners detected.")
        return 0
    print(f"{'PORT':<6} {'PROTO':<5} {'RISK':<6} {'PROCESS'}")
    print("-" * 56)
    unidentified = 0
    for e in exposed:
        label = format_listener_label(e)
        proto = e.proto or "?"
        if label == "unidentified":
            unidentified += 1
        print(f"{e.port:<6} {proto:<5} {e.risk:<6} {label}  ({e.bind})")
    print("")
    print("Dig one port:  netwatch --dig-port 11434")
    if unidentified:
        print(
            f"{unidentified} unidentified — run netwatch --setup once "
            "(enables dynamic naming for root-owned services via sudo ss/lsof)"
        )
    return 0


def cli_check(cfg: dict[str, Any] | None = None) -> int:
    cfg = cfg or load_config()
    result = run_security_check(cfg, scan=True)
    if not result.get("ok"):
        print(f"netwatch-check: ERROR {result.get('error', '?')}", file=sys.stderr)
        return 1

    unknown: list[LanDevice] = result.get("unknown") or []
    blocked_online: list[BlockedEntry] = result.get("blocked_online") or []
    print(result.get("scan_summary", "scan done"))
    print(f"unknown devices: {len(unknown)}")
    for dev in unknown:
        print(f"  ? {dev.ip}  {dev.mac}  {dev.guess or dev.vendor or '?'}")
    if blocked_online:
        print(f"blocked but online: {len(blocked_online)}")
        for b in blocked_online:
            print(f"  ! {b.label}  {b.last_ip}  ONLINE")

    new_inbound: list[str] = result.get("new_inbound") or []
    inbound: list[InboundFlow] = result.get("inbound") or []
    if cfg.get("host_exposure", {}).get("enabled", True):
        print(f"inbound sessions: {len(inbound)}  untrusted: {len(new_inbound)}")
        for f in inbound:
            if f.is_new:
                print(f"  ! {f.remote_ip} → {f.service}  {f.name}  ({f.proc or '?'})")
        exposed: list[ExposedListener] = result.get("exposed") or []
        risky = [e for e in exposed if e.risk == "alert"]
        if risky:
            print(f"exposed listeners (LAN-wide): {len(risky)}")
            for e in risky[:8]:
                label = format_listener_label(e)
                proto = f"/{e.proto}" if e.proto else ""
                print(f"  ! {e.bind}{proto}  {label}")

    exit_code = 0
    if unknown:
        for msg in deliver_unknown_alerts(cfg, unknown):
            print(msg)
        exit_code = 2

    untrusted_inbound = [f for f in inbound if f.is_new]
    if untrusted_inbound and cfg.get("host_exposure", {}).get("alert_inbound", True):
        for msg in deliver_inbound_alerts(cfg, untrusted_inbound):
            print(msg)
        exit_code = max(exit_code, 3)

    if exit_code:
        return exit_code
    print("all clear")
    return 0


def cli_restore_blocks(cfg: dict[str, Any] | None = None) -> int:
