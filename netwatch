def show_capability_prompt(stdscr, gap: CapabilityGap) -> str:
    """Return yes | no | dismiss."""
    stdscr.timeout(-1)
    try:
        while True:
            stdscr.erase()
            h, w = stdscr.getmaxyx()
            box_w = min(max(44, w - 4), 72)
            box_h = min(max(12, len(gap.body) + 10), h - 4)
            box_y = max(1, (h - box_h) // 2)
            box_x = max(0, (w - box_w) // 2)
            draw_cyber_panel(stdscr, box_y, box_x, box_h, box_w, gap.title, pair=CP_ALERT)
            y = box_y + 1
            for line in gap.body[: box_h - 8]:
                safe_addstr(stdscr, y, box_x + 2, line[: box_w - 4], cp(CP_YELLOW, dim=True))
                y += 1
            y = box_y + box_h - 5
            if gap.setup:
                dismiss_opt = (
                    " D  open anyway · don't ask again "
                    if gap.dismiss_proceeds
                    else " D  don't ask again (still needs setup) "
                )
                opts = [
                    " Y  authorize netwatch --setup & continue ",
                    " N  cancel ",
                    dismiss_opt,
                ]
            else:
                opts = [
                    " Y  install packages & continue ",
                    " N  cancel ",
                    " D  continue without · don't ask again ",
                ]
            for opt in opts:
                safe_addstr(stdscr, y, box_x + 2, opt[: box_w - 4], cp(CP_CYAN, bold=True))
                y += 1
            safe_addstr(
                stdscr,
                h - 2,
                2,
                "▸ neural consent gate — Esc cancels"[: w - 4],
                cp(CP_MAGENTA, dim=True),
            )
            stdscr.refresh()
            ch = stdscr.getch()
            if ch in (ord("y"), ord("Y")):
                return "yes"
            if ch in (ord("n"), ord("N"), 27):
                return "no"
            if ch in (ord("d"), ord("D")):
                return "dismiss"
    finally:
        stdscr.timeout(IDLE_TIMEOUT_MS)


def gate_capability(stdscr, cfg: dict[str, Any], gap: CapabilityGap | None) -> tuple[bool, str]:
    """Return (proceed, status_message). status_message set when blocked or after install."""
    if not gap:
        return True, ""
    choice = show_capability_prompt(stdscr, gap)
    if choice == "no":
        return False, "cancelled"
    if choice == "dismiss":
        dismiss_prompt(cfg, gap.prompt_id)
        if not gap.dismiss_proceeds:
            return False, "needs netwatch --setup (prompt dismissed)"
        return True, ""
    if gap.setup:
        ok, msg = run_tui_setup(cfg)
    else:
        ok, msg = install_os_packages(list(dict.fromkeys(gap.packages)))
    if not ok:
        return False, msg
    return True, msg


class ZTERouterBlocker:
    """ZTE F6600P/F8648P-style web API — MAC deny on the gateway."""

    def __init__(self, host: str, username: str, password: str, timeout: int = 12):
        host = host.rstrip("/")
        if host.startswith("http"):
            self.base_url = host
        else:
            self.base_url = f"http://{host}"
        self.username = username
        self.password = password
        self.timeout = timeout
        self.session_token = ""
        self.logged_in = False
        self.cookie_jar = CookieJar()
        self.opener = build_opener(HTTPCookieProcessor(self.cookie_jar))

    def _request(self, path: str, method: str = "GET", data: dict | None = None) -> str:
        url = f"{self.base_url}{path}"
        if data and method == "POST":
            body = urlencode(data).encode()
            req = Request(url, data=body, method="POST")
            req.add_header("Content-Type", "application/x-www-form-urlencoded")
        else:
            req = Request(url, method=method)
        req.add_header("Referer", self.base_url)
        req.add_header("User-Agent", "netwatch/2.0")
        with self.opener.open(req, timeout=self.timeout) as resp:
            return resp.read().decode("utf-8", errors="replace")

    def login(self) -> None:
        raw = self._request("/?_type=loginData&_tag=login_entry")
        try:
            data = json.loads(raw)
        except json.JSONDecodeError as exc:
            raise RuntimeError("router login page parse failed") from exc
        self.session_token = str(data.get("sess_token") or "")
        if int(data.get("lockingTime") or 0) > 0:
            raise RuntimeError(f"router login locked ({data['lockingTime']}s)")

        token_xml = self._request("/?_type=loginData&_tag=login_token")
        try:
            login_token = (ET.fromstring(token_xml).text or "").strip()
        except ET.ParseError:
            m = re.search(r">([^<]+)<", token_xml)
            login_token = m.group(1).strip() if m else ""
        if not login_token:
            raise RuntimeError("router login token missing")

        pwd_hash = hashlib.sha256((self.password + login_token).encode()).hexdigest()
        result_raw = self._request(
            "/?_type=loginData&_tag=login_entry",
            "POST",
            {
                "action": "login",
                "Username": self.username,
                "Password": pwd_hash,
                "_sessionTOKEN": self.session_token,
            },
        )
        result = json.loads(result_raw)
        self.session_token = str(result.get("sess_token") or self.session_token)
        if not result.get("login_need_refresh"):
            raise RuntimeError(str(result.get("loginErrMsg") or "router login failed"))
        self.logged_in = True

    def _load_view(self, view: str) -> None:
        ts = int(time.time() * 1000)
        resp = self._request(f"/?_type=menuView&_tag={view}&Menu3Location=0&_={ts}")
        if "SessionTimeout" in resp:
            self.logged_in = False
            self.login()
            self._load_view(view)

    def block_mac(self, mac: str, cfg: dict[str, Any]) -> tuple[bool, str]:
        rb = cfg.get("countermeasures", {}).get("router_block", {})
        view = str(rb.get("mac_filter_view") or "wlanMacFilter")
        data_tag = str(rb.get("mac_filter_data") or "wlan_macfilter_lua.lua")
        mac_fmt = mac.upper().replace("-", ":")
        self._load_view(view)
        ts = int(time.time() * 1000)

        # Try standard ZTE POST shape (deny list entry).
        post_variants = [
            {
                "IF_ACTION": "Apply",
                "Enable": "1",
                "Policy": "0",
                "MACAddress": mac_fmt,
                "Name": f"netwatch-{mac_fmt[-8:]}",
                "_sessionTOKEN": self.session_token,
            },
            {
                "IF_ACTION": "Add",
                "Enable": "1",
                "FilterPolicy": "0",
                "MACAddr": mac_fmt,
                "_sessionTOKEN": self.session_token,
            },
        ]
        for payload in post_variants:
            try:
                resp = self._request(f"/?_type=menuData&_tag={data_tag}&_={ts}", "POST", payload)
                if "SessionTimeout" in resp:
                    continue
                if "IF_ERRORSTR" in resp and "SUCC" not in resp and "success" not in resp.lower():
                    if "error" in resp.lower() or "fail" in resp.lower():
                        continue
                return True, f"router MAC deny {mac_fmt}"
            except (RuntimeError, OSError, json.JSONDecodeError):
                continue
        return False, "router MAC filter API unavailable (PC quarantine still active)"


def router_block_mac(cfg: dict[str, Any], mac: str, ip: str, action: str) -> tuple[bool, str]:
    rb = cfg.get("countermeasures", {}).get("router_block", {})
    if action != "block" or not rb.get("enabled", True):
        return True, "router skip"
    secrets = load_secrets()
    user = secrets.get(str(rb.get("username_env") or "ROUTER_USER"), "admin")
    password = secrets.get(str(rb.get("password_env") or "ROUTER_PASSWORD"), "")
    if not password:
        return False, "router password not configured — run: netwatch --setup"
    host = router_admin_url(cfg)
    if not host:
        return False, "router host unknown — set router.url or check default route"
    try:
        client = ZTERouterBlocker(host, user, password)
        client.login()
        if action == "block":
            return client.block_mac(mac, cfg)
        return True, "router unblock logged"
    except (RuntimeError, OSError, URLError, json.JSONDecodeError) as exc:
        return False, str(exc)[:200]


def blocked_path(cfg: dict[str, Any]) -> Path:
    return expand_path(cfg.get("countermeasures", {}).get("block_file", str(BLOCKED_PATH)))


def load_blocked(cfg: dict[str, Any]) -> dict[str, dict]:
    path = blocked_path(cfg)
    if not path.is_file():
        return {}
    try:
        data = json.loads(path.read_text())
        return data if isinstance(data, dict) else {}
    except json.JSONDecodeError:
        return {}


def save_blocked(cfg: dict[str, Any], blocked: dict[str, dict]) -> None:
    path = blocked_path(cfg)
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(blocked, indent=2, sort_keys=True) + "\n")


def blocked_entries(cfg: dict[str, Any]) -> list[BlockedEntry]:
    rows: list[BlockedEntry] = []
    for mac, entry in sorted(load_blocked(cfg).items()):
        rows.append(
            BlockedEntry(
                mac=mac.lower(),
                last_ip=str(entry.get("last_ip") or "?"),
                label=str(entry.get("label") or ""),
                reason=str(entry.get("reason") or ""),
                blocked_at=str(entry.get("blocked_at") or ""),
                method=str(entry.get("method") or ""),
                online=bool(entry.get("online")),
                last_ping=str(entry.get("last_ping") or ""),
            )
        )
    return rows


def is_blocked_mac(cfg: dict[str, Any], mac: str) -> bool:
    return mac.lower() in load_blocked(cfg)


def device_display_name(mac: str, known: dict[str, dict], entry: dict | None = None) -> str:
    src = entry or known.get(mac.lower(), {})
    return (
        (src.get("label") or "").strip()
        or (src.get("auto_guess") or "").strip()
        or (src.get("hostname") or "").split(".")[0]
        or (src.get("vendor") or "").strip()
        or mac
    )


def ping_check(ip: str, iface: str) -> bool:
    if not ip or ip.count(".") != 3:
        return False
    args = ["ping", "-c", "1", "-W", "1", ip]
    if iface:
        args[1:1] = ["-I", iface]
    return subprocess.call(args, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL) == 0


def update_blocked_ping_status(cfg: dict[str, Any], iface: str) -> dict[str, dict]:
    blocked = load_blocked(cfg)
    now = time.strftime("%Y-%m-%dT%H:%M:%S")
    for mac, entry in blocked.items():
        ip = str(entry.get("last_ip") or "")
        online = ping_check(ip, iface) if ip else False
        entry["online"] = online
        entry["last_ping"] = now
        blocked[mac] = entry
    save_blocked(cfg, blocked)
    return blocked


def _sudo_prefix(cfg: dict[str, Any]) -> list[str]:
    if os.geteuid() == 0:
        return []
    if cfg.get("countermeasures", {}).get("sudo_non_interactive", True):
        return ["sudo", "-n"]
    return ["sudo"]


def _run_priv(cmd: list[str], cfg: dict[str, Any], timeout: int = 10) -> tuple[int, str]:
    full = _sudo_prefix(cfg) + cmd
    try:
        proc = subprocess.run(full, capture_output=True, text=True, timeout=timeout, check=False)
        out = (proc.stdout or proc.stderr or "").strip()
        return proc.returncode, out
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return 1, ""


def apply_nftables_blocks(cfg: dict[str, Any], blocked: dict[str, dict]) -> tuple[bool, str]:
    ips = sorted({str(e.get("last_ip")) for e in blocked.values() if e.get("last_ip")})
    macs = sorted(
        {
            str(e.get("mac") or mac).lower().replace("-", ":")
            for mac, e in blocked.items()
            if (e.get("mac") or mac)
        }
    )
    use_mac = cfg.get("countermeasures", {}).get("block_by_mac", True)
    if not ips and not (use_mac and macs):
        code, _ = _run_priv(["nft", "list", "table", "inet", NFT_TABLE], cfg)
        if code == 0:
            _run_priv(["nft", "delete", "table", "inet", NFT_TABLE], cfg)
        return True, "no blocked targets"

    code, _ = _run_priv(["nft", "list", "table", "inet", NFT_TABLE], cfg)
    if code != 0:
        rc, _ = _run_priv(["nft", "add", "table", "inet", NFT_TABLE], cfg)
        if rc != 0:
            return False, "nftables: need netwatch --setup (sudo)"
        _run_priv(
            [
                "nft",
                "add",
                "chain",
                "inet",
                NFT_TABLE,
                NFT_CHAIN_IN,
                "{ type filter hook input priority 0; policy accept; }",
            ],
            cfg,
        )
        _run_priv(
            [
                "nft",
                "add",
                "chain",
                "inet",
                NFT_TABLE,
                NFT_CHAIN_OUT,
                "{ type filter hook output priority 0; policy accept; }",
            ],
            cfg,
        )

    _run_priv(["nft", "flush", "chain", "inet", NFT_TABLE, NFT_CHAIN_IN], cfg)
    _run_priv(["nft", "flush", "chain", "inet", NFT_TABLE, NFT_CHAIN_OUT], cfg)
    applied = 0
    for ip in ips:
        c1, _ = _run_priv(["nft", "add", "rule", "inet", NFT_TABLE, NFT_CHAIN_IN, "ip", "saddr", ip, "drop"], cfg)
        c2, _ = _run_priv(["nft", "add", "rule", "inet", NFT_TABLE, NFT_CHAIN_OUT, "ip", "daddr", ip, "drop"], cfg)
        if c1 == 0 and c2 == 0:
            applied += 1
    mac_applied = 0
    if use_mac:
        for mac in macs:
            c1, _ = _run_priv(
                ["nft", "add", "rule", "inet", NFT_TABLE, NFT_CHAIN_IN, "ether", "saddr", mac, "drop"],
                cfg,
            )
            c2, _ = _run_priv(
                ["nft", "add", "rule", "inet", NFT_TABLE, NFT_CHAIN_OUT, "ether", "daddr", mac, "drop"],
                cfg,
            )
            if c1 == 0 or c2 == 0:
                mac_applied += 1
    if applied == 0 and mac_applied == 0:
        return False, "nftables rules failed — run: netwatch --setup"
    parts = []
    if applied:
        parts.append(f"{applied} IP(s)")
    if mac_applied:
        parts.append(f"{mac_applied} MAC(s)")
    return True, f"pc-firewall ({', '.join(parts)})"


def apply_firewalld_blocks(cfg: dict[str, Any], blocked: dict[str, dict]) -> tuple[bool, str]:
    if not shutil.which("firewall-cmd"):
        return False, "firewall-cmd not installed"
    ips = sorted({str(e.get("last_ip")) for e in blocked.values() if e.get("last_ip")})
    applied = 0
    for ip in ips:
        rule = f'rule family="ipv4" source address="{ip}" drop'
        code, _ = _run_priv(["firewall-cmd", "--permanent", f"--add-rich-rule={rule}"], cfg, timeout=20)
        if code == 0:
            applied += 1
    if applied:
        _run_priv(["firewall-cmd", "--reload"], cfg, timeout=20)
    return True, f"firewalld rich rules for {applied} IP(s)"


def run_block_script(cfg: dict[str, Any], mac: str, ip: str, action: str) -> tuple[bool, str]:
    script = expand_path(cfg.get("countermeasures", {}).get("block_script", ""))
    if not script.is_file():
        return False, "block script not found"
    env = os.environ.copy()
    env.update(
        {
            "NETWATCH_MAC": mac,
            "NETWATCH_IP": ip,
            "NETWATCH_ACTION": action,
        }
    )
    try:
        proc = subprocess.run(
            [str(script), action, mac, ip],
            capture_output=True,
            text=True,
            timeout=30,
            check=False,
            env=env,
        )
        msg = (proc.stdout or proc.stderr or "").strip() or f"exit {proc.returncode}"
        return proc.returncode == 0, msg[:200]
    except (subprocess.TimeoutExpired, OSError) as exc:
        return False, str(exc)[:200]


def apply_block_rules(
    cfg: dict[str, Any],
    blocked: dict[str, dict] | None = None,
    *,
    manual: bool = False,
) -> tuple[bool, str]:
    cm = cfg.get("countermeasures", {})
    if not cm.get("enabled", True):
        return False, "countermeasures disabled"
    if not manual and cm.get("auto_quarantine", False) is not True:
        return False, "quarantine is manual-only (press b in identify)"
    blocked = blocked if blocked is not None else load_blocked(cfg)
    method = str(cm.get("method") or "full").lower()
    notes: list[str] = []
    ok_any = False

    if method in ("full", "nftables", "both"):
        ok, msg = apply_nftables_blocks(cfg, blocked)
        notes.append(msg)
        ok_any = ok_any or ok
    if method in ("full", "firewalld", "both"):
        ok, msg = apply_firewalld_blocks(cfg, blocked)
        notes.append(msg)
        ok_any = ok_any or ok
    if method in ("log", "script"):
        return True, f"registry: {len(blocked)} blocked"
    if not ok_any and method != "log":
        return False, " · ".join(notes) or "enforcement failed"
    return True, " · ".join(notes) or "rules applied"


def sync_blocked_from_arp(cfg: dict[str, Any], iface: str) -> tuple[int, str]:
    """Update blocked IPs from ARP and re-apply rules if a device got a new DHCP lease."""
    blocked = load_blocked(cfg)
    if not blocked or not iface:
        return 0, ""
    devices = parse_neigh(iface)
    mac_ip = {d.mac.lower(): d.ip for d in devices}
    changed = 0
    for mac, entry in blocked.items():
        live_ip = mac_ip.get(mac.lower())
        if live_ip and live_ip != entry.get("last_ip"):
            entry["last_ip"] = live_ip
            entry["last_seen"] = time.strftime("%Y-%m-%dT%H:%M:%S")
            changed += 1
    if not changed:
        return 0, ""
    save_blocked(cfg, blocked)
    apply_block_rules(cfg, blocked, manual=True)
    return changed, f"updated {changed} blocked IP(s) from ARP"


def block_device(
    cfg: dict[str, Any],
    mac: str,
    ip: str,
    *,
    label: str = "",
    reason: str = "",
    known: dict[str, dict] | None = None,
    interactive_setup: bool = False,
) -> tuple[bool, str]:
    cm = cfg.get("countermeasures", {})
    if not cm.get("enabled", True):
        return False, "countermeasures disabled"

    ready, ready_msg = ensure_enforcement_ready(cfg, interactive=interactive_setup)
    if not ready:
        return False, ready_msg

    mac = mac.lower()
    _, gateway, local = default_route()
    if cm.get("protect_gateway", True) and ip == gateway:
        return False, "refusing to block gateway"
    if cm.get("protect_self", True) and ip == local:
        return False, "refusing to block this PC"

    known = known if known is not None else load_known(expand_path(cfg["alerts"]["state_file"]))
    name = label.strip() or device_display_name(mac, known)
    now = time.strftime("%Y-%m-%dT%H:%M:%S")
    method = str(cm.get("method") or "full")

    blocked = load_blocked(cfg)
    blocked[mac] = {
        "mac": mac,
        "last_ip": ip,
        "label": name,
        "reason": reason.strip() or "manual block",
        "blocked_at": now,
        "method": method,
        "online": ping_check(ip, default_route()[0]),
        "last_ping": now,
        "layers": [],
    }
    save_blocked(cfg, blocked)

    layers: list[str] = []
    ok_pc, msg_pc = apply_block_rules(cfg, blocked, manual=True)
    if ok_pc:
        layers.append(msg_pc.split(" · ")[0] if " · " in msg_pc else msg_pc)

    ok_router, msg_router = router_block_mac(cfg, mac, ip, "block")
    if ok_router and "skip" not in msg_router:
        layers.append("router-wifi")

    script = expand_path(cm.get("block_script", ""))
    if script.is_file():
        s_ok, s_msg = run_block_script(cfg, mac, ip, "block")
        if s_ok:
            layers.append("router-hook")

    blocked[mac]["layers"] = layers
    save_blocked(cfg, blocked)

    if not layers:
        return False, f"QUARANTINE FAILED — {msg_pc}; router: {msg_router}"
    detail = ", ".join(layers)
    return True, f"QUARANTINED {name} ({ip}) — {detail}"


def unblock_device(cfg: dict[str, Any], mac: str) -> tuple[bool, str]:
    mac = mac.lower()
    blocked = load_blocked(cfg)
    entry = blocked.pop(mac, None)
    if not entry:
        return False, "not in block registry"
    save_blocked(cfg, blocked)
    ip = str(entry.get("last_ip") or "")
    apply_block_rules(cfg, blocked, manual=True)
    script = expand_path(cfg.get("countermeasures", {}).get("block_script", ""))
    if script.is_file() and ip:
        run_block_script(cfg, mac, ip, "unblock")
    label = str(entry.get("label") or mac)
    return True, f"unblocked {label}"


