CYBER_SPINNERS = ("◢◣◢◣", "◣◢◣◢", "◢◣◢◣", "◥◤◥◤")
CYBER_BAR_LEVELS = "░▒▓█"

# Color pairs — init in init_cyber_theme()
CP_ALERT = 1
CP_CYAN = 2
CP_MAGENTA = 3
CP_GREEN = 4
CP_YELLOW = 5
CP_BLUE = 6
CP_WHITE = 7


def init_cyber_theme() -> None:
    curses.start_color()
    curses.use_default_colors()
    pairs = (
        (CP_ALERT, curses.COLOR_RED, -1),
        (CP_CYAN, curses.COLOR_CYAN, -1),
        (CP_MAGENTA, curses.COLOR_MAGENTA, -1),
        (CP_GREEN, curses.COLOR_GREEN, -1),
        (CP_YELLOW, curses.COLOR_YELLOW, -1),
        (CP_BLUE, curses.COLOR_BLUE, -1),
        (CP_WHITE, curses.COLOR_WHITE, -1),
    )
    for idx, fg, bg in pairs:
        try:
            curses.init_pair(idx, fg, bg)
        except curses.error:
            pass


def cp(pair: int, *, bold: bool = False, dim: bool = False) -> int:
    attr = curses.color_pair(pair)
    if bold:
        attr |= curses.A_BOLD
    if dim:
        attr |= curses.A_DIM
    return attr


def safe_addstr(win, y: int, x: int, text: str, attr: int = 0, width: int | None = None) -> None:
    if not text:
        return
    h, w = win.getmaxyx()
    if y < 0 or x < 0 or y >= h - 1 or x >= w - 1:
        return
    limit = (width if width is not None else w - x) - 1
    if limit <= 0:
        return
    try:
        win.addnstr(y, x, text[:limit], limit, attr)
    except curses.error:
        pass


def loader_inner_width(term_w: int) -> int:
    """Responsive loader width — bigger on large terminals."""
    if term_w >= 140:
        return min(term_w - 8, 100)
    if term_w >= 100:
        return min(term_w - 6, 86)
    if term_w >= 80:
        return min(term_w - 6, 68)
    return max(36, min(term_w - 4, 52))


def loader_title_rule(inner_w: int) -> str:
    rule_len = max(24, min(inner_w - 16, inner_w // 2 + 12))
    return "▀" * rule_len


def loader_box_row(inner_w: int, content: str = "") -> str:
    text = content.center(inner_w)[:inner_w]
    return f"║{text}║"


def loader_progress_bar(frame: int, bar_w: int) -> str:
    """Full-width animated bar; wave slides inside [ ... ]."""
    inner = max(16, bar_w - 2)
    wave = max(6, inner // 5)
    head = (frame * 2) % (inner + wave)
    cells: list[str] = []
    for i in range(inner):
        dist = head - i
        if dist < 0 or dist >= wave:
            cells.append(CYBER_BAR_LEVELS[0])
        else:
            level = min(3, (dist * 4) // max(1, wave))
            cells.append(CYBER_BAR_LEVELS[level])
    return f"[{''.join(cells)}]"


def cyber_pulse(frame: int) -> str:
    return CYBER_SPINNERS[frame % len(CYBER_SPINNERS)]


def draw_cyber_loader(stdscr, status: str, frame: int) -> None:
    h, w = stdscr.getmaxyx()
    stdscr.erase()

    inner_w = loader_inner_width(w)
    bar_w = max(20, inner_w - 8)
    spin = cyber_pulse(frame)
    stat = (status or "SYNC").upper()[: max(6, inner_w // 4)]

    top = "╔" + ("═" * inner_w) + "╗"
    bottom = "╚" + ("═" * inner_w) + "╝"
    bar = loader_progress_bar(frame, bar_w)
    art = [
        top,
        loader_box_row(inner_w),
        loader_box_row(inner_w, "▄▐  N E T W A T C H  ▐▄  // v2.0"),
        loader_box_row(inner_w, loader_title_rule(inner_w)),
        loader_box_row(inner_w),
        loader_box_row(inner_w, f"{spin}   {stat}"),
        loader_box_row(inner_w, bar),
        loader_box_row(inner_w, ">> uplink // probe // sync <<"),
        loader_box_row(inner_w),
        bottom,
    ]

    box_w = inner_w + 2
    box_h = len(art)
    y0 = max(0, (h - box_h - 2) // 2)
    x0 = max(0, (w - box_w) // 2)

    for i, line in enumerate(art):
        y = y0 + i
        if y >= h - 1:
            break
        if i == 0 or i == box_h - 1:
            attr = cp(CP_CYAN, bold=True)
        elif i in (2, 3, 6, 7):
            attr = cp(CP_CYAN, bold=True)
        elif i == 5:
            attr = cp(CP_MAGENTA, bold=True)
        else:
            attr = cp(CP_MAGENTA, dim=True)
        safe_addstr(stdscr, y, x0, line[: box_w - 1], attr, box_w)

    tagline = "◈ NEURAL LINK ESTABLISHING ◈"
    safe_addstr(
        stdscr,
        min(h - 1, y0 + box_h + 1),
        max(0, (w - len(tagline)) // 2),
        tagline,
        cp(CP_YELLOW, dim=True),
    )
    stdscr.refresh()


def cyber_transition(stdscr, label: str, frames: int = 3) -> None:
    for i in range(max(1, frames)):
        draw_cyber_loader(stdscr, label, i)
        time.sleep(0.045)


NAV_TRANSITION_FRAMES = 3


def cyber_screen_enter(stdscr, label: str) -> None:
    cyber_transition(stdscr, label, frames=NAV_TRANSITION_FRAMES)


def cyber_screen_exit(stdscr, label: str = "BACK") -> None:
    cyber_transition(stdscr, label, frames=NAV_TRANSITION_FRAMES)


def run_with_cyber_loader(stdscr, status: str, func, *args, **kwargs):
    result: list[Any] = []
    error: list[BaseException] = []

    def work() -> None:
        try:
            result.append(func(*args, **kwargs))
        except BaseException as exc:  # noqa: BLE001 — surface in UI thread
            error.append(exc)

    thread = threading.Thread(target=work, daemon=True)
    thread.start()
    frame = 0
    while thread.is_alive():
        draw_cyber_loader(stdscr, status, frame)
        frame += 1
        time.sleep(0.065)
    if error:
        raise error[0]
    cyber_transition(stdscr, "ONLINE", frames=NAV_TRANSITION_FRAMES)
    return result[0]


def draw_cyber_panel(
    win,
    y: int,
    x: int,
    h: int,
    w: int,
    title: str,
    *,
    pair: int = CP_CYAN,
) -> None:
    if h < 3 or w < 6:
        return
    tl, tr, bl, br, hz, vt = "╔", "╗", "╚", "╝", "═", "║"
    title_text = f"◈ {title.upper()} ◈"
    inner_w = w - 2
    if len(title_text) + 4 > inner_w:
        title_text = title_text[: max(4, inner_w - 5)] + "…"
    pad = max(0, inner_w - len(title_text))
    left_pad = pad // 2
    top = tl + (hz * left_pad) + title_text + (hz * (pad - left_pad)) + tr
    safe_addstr(win, y, x, top[: w - 1], cp(pair, bold=True), w)
    for row in range(y + 1, y + h - 1):
        safe_addstr(win, row, x, vt, cp(pair))
        safe_addstr(win, row, x + w - 1, vt, cp(pair))
    safe_addstr(win, y + h - 1, x, bl + (hz * inner_w) + br[:1], cp(pair), w)


def draw_cyber_hud_bar(win, y: int, w: int, left: str, right: str, *, pair: int = CP_MAGENTA) -> None:
    if y >= win.getmaxyx()[0] - 1 or w < 8:
        return
    safe_addstr(win, y, 0, "▌", cp(pair, bold=True))
    safe_addstr(win, y, 1, left[: max(0, w - len(right) - 4)], cp(CP_CYAN, bold=True), w - len(right) - 2)
    safe_addstr(win, y, max(1, w - len(right) - 1), right[: w - 2], cp(CP_YELLOW, dim=True))


