def format_listener_label(entry: ExposedListener) -> str:
    if entry.proc:
        label = entry.proc
        if entry.pid:
            label += f"·{entry.pid}"
        return label
    if entry.detail and entry.detail != "unidentified":
        return entry.detail
    return "unidentified"


