def cfg_get(cfg: dict[str, Any], path: list[str]) -> Any:
    node: Any = cfg
    for key in path:
        node = node[key]
    return node


def cfg_set(cfg: dict[str, Any], path: list[str], value: Any) -> None:
    node = cfg
    for key in path[:-1]:
        node = node.setdefault(key, {})
    node[path[-1]] = value


