def collect_state(
    cfg: dict[str, Any],
    iface: str,
    acknowledge: bool = False,
    *,
    force_identify: bool = False,
    network: bool = True,
) -> DashboardState:
    state = DashboardState()
    devices = parse_neigh(iface) if iface else []
    known_path = expand_path(cfg["alerts"]["state_file"])
    known = load_known(known_path)
    state.router_clients, state.router_note = router_clients(cfg)

    if cfg["alerts"].get("enabled", True):
        known = update_known(known, devices, acknowledge)
    else:
        pass

    enrich_devices(
        devices,
        known,
        state.router_clients,
        cfg,
        force_refresh=force_identify,
        network=network,
    )
    save_known(known_path, known)
    state.devices = devices

    if cfg["alerts"].get("enabled", True):
        state.new_macs = [d.mac for d in devices if device_needs_attention(d, known, cfg)]
        for dev in devices:
            dev.is_new = dev.mac in state.new_macs
    else:
        state.new_macs = []

    if cfg["tailscale"].get("enabled", True):
        state.tailscale, ts_note = tailscale_peers()
        state.status = ts_note

    known_for_out = load_known(expand_path(cfg["alerts"]["state_file"]))
    state.outbound = outbound_flows(
        cfg,
        known_for_out,
        state.router_clients,
        state.tailscale,
        limit=10,
    )

    if cfg.get("countermeasures", {}).get("enabled", True):
        sync_blocked_from_arp(cfg, iface)
        state.blocked = blocked_entries(cfg)
        blocked_macs = {b.mac for b in state.blocked}
        for dev in devices:
            if dev.mac in blocked_macs:
                dev.notes = "BLOCKED"
                dev.is_new = False

    if cfg.get("host_exposure", {}).get("enabled", True):
        (
            state.inbound,
            state.new_inbound,
            state.bridges,
            state.exposed,
            state.login_sessions,
        ) = collect_host_exposure(
            cfg, known_for_out, state.router_clients, state.tailscale
        )

    return state


