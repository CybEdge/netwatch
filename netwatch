        ch = stdscr.getch()
        if ch in (ord("q"), ord("Q"), 27, 10, 13, ord(" ")):
            cyber_screen_exit(stdscr)
            break
        if ch in (curses.KEY_UP, ord("k")) and offset > 0:
            offset -= 1
        if ch in (curses.KEY_DOWN, ord("j")) and offset + visible < len(lines):
            offset += 1


def _lan_line_attr(device: LanDevice, scanned: bool) -> int:
    if device.is_new:
        return cp(CP_ALERT, bold=True)
    if device.label:
        return cp(CP_GREEN)
    if scanned:
        return cp(CP_CYAN)
    return cp(CP_WHITE, dim=True)


def render(
    stdscr,
    cfg,
    dash,
    status,
    scanned,
    frame: int = 0,
    panel_page: int = 0,
) -> None:
    stdscr.erase()
    h, w = stdscr.getmaxyx()
    _, gateway, local = default_route()
    pulse = cyber_pulse(frame)
    clock = time.strftime("%H:%M:%S")
    per_page = panels_per_page(cfg)
    all_panels = build_dashboard_panels(cfg, dash, scanned)
    pages = panel_page_count(len(all_panels), cfg)
    panel_page = panel_page % pages
    visible = all_panels[panel_page * per_page : (panel_page + 1) * per_page]
    page_label = f"panels {panel_page * per_page + 1}-{panel_page * per_page + len(visible)}/{len(all_panels)}"

    left = (
        f" NETWATCH // CYBERNETIC UPLINK  {pulse}  "
        f"node·{local or '?'}  gw·{gateway or '?'}  {clock} "
    )
    draw_cyber_hud_bar(
        stdscr,
        0,
        w,
        left,
        f"◈ {page_label} · {binding_label(cfg, 'panel_next')}/{binding_label(cfg, 'panel_prev')} ◈",
        pair=CP_MAGENTA,
    )
    row = 1
    safe_addstr(stdscr, row, 0, ("═" * max(0, w - 1))[: w - 1], cp(CP_CYAN, dim=True))
    row += 1

    if cfg["alerts"].get("banner") and dash.new_macs:
        alert = (
            f" ⚠ UNKNOWN: {len(dash.new_macs)} device(s) — "
            f"{binding_label(cfg, 'block')}·block  "
            f"{binding_label(cfg, 'identify')}·identify  "
            f"{binding_label(cfg, 'acknowledge')}·trust "
        )
        safe_addstr(stdscr, row, 0, alert[: w - 1], cp(CP_ALERT, bold=True), w)
        row += 1
        safe_addstr(stdscr, row, 0, ("─" * max(0, w - 1))[: w - 1], cp(CP_ALERT, dim=True))
        row += 1

    he = cfg.get("host_exposure", {})
    if he.get("enabled", True) and he.get("banner", True) and dash.new_inbound:
        alert = (
            f" ⚠ HOST EXPOSURE: {len(dash.new_inbound)} remote peer(s) on THIS PC "
            f"— {binding_label(cfg, 'host_exposure')}·detail  "
            f"{binding_label(cfg, 'trust_inbound')}·trust "
        )
        safe_addstr(stdscr, row, 0, alert[: w - 1], cp(CP_ALERT, bold=True), w)
        row += 1
        safe_addstr(stdscr, row, 0, ("─" * max(0, w - 1))[: w - 1], cp(CP_ALERT, dim=True))
        row += 1

    body_h = max(8, h - row - 2)
    cols, rows = 2, 2
    gap_x, gap_y = 1, 1
    cell_w = max(20, (w - gap_x) // cols)
    cell_h = max(6, (body_h - gap_y) // rows)

    for idx in range(per_page):
        if idx >= len(visible):
            break
        panel = visible[idx]
        pr, pc = idx // cols, idx % cols
        py = row + pr * (cell_h + gap_y)
        px = pc * (cell_w + gap_x)
        pw = cell_w if pc == 0 else min(cell_w, w - px - 1)
        extra = f" ({panel.total})" if panel.total > items_per_panel(cfg) else ""
        title = f"{panel.title}{extra}"
        draw_cyber_panel(stdscr, py, px, cell_h, pw, title, pair=panel.pair)
        put_lines(
            stdscr,
            py + 1,
            px + 2,
            pw - 4,
            panel.lines,
            cp(CP_WHITE, dim=True),
            line_attrs=panel.line_attrs,
        )

    draw_cyber_footer(stdscr, h - 1, w, status, cfg)


def main(stdscr) -> None:
    curses.curs_set(0)
    init_cyber_theme()
    stdscr.timeout(IDLE_TIMEOUT_MS)

    iface, _, local = default_route()
    cfg = load_config()
    ensure_oui_cache(cfg)
    scanned = False
    ui_status = FlashStatus(dashboard_status_legend(cfg), ttl=status_flash_seconds(cfg))
    ui_frame = 0
    panel_page = 0
    cyber_screen_enter(stdscr, "BOOT")
    dash = run_with_cyber_loader(stdscr, "SYNC", collect_state, cfg, iface)
    last_refresh = time.time()
    auto = int(cfg.get("display", {}).get("refresh_seconds") or 0)

    while True:
        render(stdscr, cfg, dash, ui_status.current(), scanned, ui_frame, panel_page=panel_page)
        ui_frame += 1
        if auto and time.time() - last_refresh >= auto:
            cfg = load_config()
            ui_status.legend = dashboard_status_legend(cfg)
            ui_status.ttl = status_flash_seconds(cfg)
            dash = collect_state(cfg, iface)
            ui_status.flash(f"auto {time.strftime('%H:%M:%S')}")
            last_refresh = time.time()

        ch = stdscr.getch()
        if ch == -1:
            continue
        if ch == 27 or key_matches_action(cfg, ch, "quit"):
            break
        if key_matches_action(cfg, ch, "refresh"):
            cfg = load_config()
            ui_status.legend = dashboard_status_legend(cfg)
            ui_status.ttl = status_flash_seconds(cfg)
            auto = int(cfg.get("display", {}).get("refresh_seconds") or 0)
            dash = collect_state(cfg, iface)
            ui_status.flash(f"refresh {time.strftime('%H:%M:%S')}")
            last_refresh = time.time()
        elif key_matches_action(cfg, ch, "panel_next"):
            panels = build_dashboard_panels(cfg, dash, scanned)
            panel_page = advance_panel_page(panel_page, len(panels), cfg)
            ui_status.flash(f"panel page {panel_page + 1}/{panel_page_count(len(panels), cfg)}")
        elif key_matches_action(cfg, ch, "panel_prev"):
            panels = build_dashboard_panels(cfg, dash, scanned)
            panel_page = retreat_panel_page(panel_page, len(panels), cfg)
            ui_status.flash(f"panel page {panel_page + 1}/{panel_page_count(len(panels), cfg)}")
        elif key_matches_action(cfg, ch, "options"):
            msg = show_options(stdscr, cfg)
            cfg = load_config()
            ui_status.legend = dashboard_status_legend(cfg)
            ui_status.ttl = status_flash_seconds(cfg)
            auto = int(cfg.get("display", {}).get("refresh_seconds") or 0)
            dash = collect_state(cfg, iface, network=False)
            if msg:
                ui_status.flash(msg, ttl=max(ui_status.ttl, 5.0))
        elif key_matches_action(cfg, ch, "block"):
            unknown = unknown_devices(dash.devices, cfg)
            if unknown:
                ok, gate_msg = gate_capability(stdscr, cfg, check_countermeasures_gap(cfg))
                if not ok:
                    ui_status.flash(gate_msg if gate_msg != "cancelled" else "block cancelled")
                    continue
                if gate_msg:
                    ui_status.flash(gate_msg)
                msg = quick_block_unknown(stdscr, cfg, dash.devices)
                dash = collect_state(cfg, iface, network=False)
                ui_status.flash(msg)
            else:
                ui_status.flash("no unknown devices — use G for registry")
        elif key_matches_action(cfg, ch, "registry"):
            msg = show_quarantine_registry(stdscr, cfg, iface)
            dash = collect_state(cfg, iface, network=False)
            if msg:
                ui_status.flash(msg)
        elif key_matches_action(cfg, ch, "acknowledge"):
            dash = collect_state(cfg, iface, acknowledge=True)
            ui_status.flash("acknowledged current MACs")
        elif key_matches_action(cfg, ch, "trust_inbound"):
            n = trust_inbound_ips(cfg, dash.new_inbound)
            dash = collect_state(cfg, iface, network=False)
            ui_status.flash(f"trusted {n} inbound peer(s)" if n else "no new inbound peers")
        elif key_matches_action(cfg, ch, "host_exposure"):
            msg = show_host_exposure(stdscr, cfg, iface)
            dash = collect_state(cfg, iface, network=False)
            if msg:
                ui_status.flash(msg)
        elif key_matches_action(cfg, ch, "identify"):
            msg = show_identify(stdscr, cfg, iface)
            dash = collect_state(cfg, iface, network=False)
            if msg:
                ui_status.flash(msg)
        elif key_matches_action(cfg, ch, "scan"):
            if not iface or not local:
                ui_status.flash("scan failed: no interface")
                continue
            ok, gate_msg = gate_capability(stdscr, cfg, check_house_scan_gap(cfg))
            if not ok:
                ui_status.flash(gate_msg if gate_msg != "cancelled" else "scan cancelled")
                continue
            if gate_msg:
                ui_status.flash(gate_msg)

            def do_scan() -> tuple[DashboardState, str]:
                _, summary = house_scan(cfg, iface, local)
                time.sleep(0.3)
                return collect_state(cfg, iface, force_identify=True), summary

            dash, scan_summary = run_with_cyber_loader(stdscr, "HOUSE", do_scan)
            scanned = True
            ui_status.flash(scan_summary)
        elif key_matches_action(cfg, ch, "help"):
            show_help(stdscr, cfg)


def ensure_runtime_data_files() -> None:
    """Create empty local state files — never seed personal LAN data."""
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    if not BLOCKED_PATH.is_file():
        BLOCKED_PATH.write_text("{}\n")
    if not TRUSTED_PEERS_PATH.is_file():
        TRUSTED_PEERS_PATH.write_text("{}\n")
    if not MANUAL_PATH.is_file():
        MANUAL_PATH.write_text("[]\n")
    known_default = expand_path(DEFAULT_CONFIG["alerts"]["state_file"])
    if not known_default.is_file():
        known_default.write_text("{}\n")
    if not ALERT_STATE_PATH.is_file():
        ALERT_STATE_PATH.write_text('{"notified_macs": {}}\n')
    secrets_example = CONFIG_DIR / "secrets.env.example"
    if not secrets_example.is_file():
        secrets_example.write_text(
            "# Copy to secrets.env (chmod 600). Never commit secrets.env.\n"
            "ROUTER_USER=\n"
            "ROUTER_PASSWORD=\n"
            "NETWATCH_SMTP_USER=\n"
            "NETWATCH_SMTP_PASS=\n"
        )


if __name__ == "__main__":
    if not shutil.which("ip"):
        raise SystemExit("Requires 'ip' from iproute.")
    if yaml is None:
        raise SystemExit("Requires PyYAML (dnf install python3-pyyaml)")
    ensure_runtime_data_files()
    if not CONFIG_PATH.is_file():
        CONFIG_PATH.write_text(
            "# Generated defaults\n" + yaml.dump(DEFAULT_CONFIG, default_flow_style=False, sort_keys=False)
        )

    args = sys.argv[1:]
    if args and args[0] in ("--check", "-c", "check"):
        raise SystemExit(cli_check())
    if args and args[0] in ("--new-user", "new-user", "--reset-auth", "reset-auth"):
        raise SystemExit(cli_new_user())
    if args and args[0] in ("--configure", "configure"):
        raise SystemExit(cli_configure())
    if args and args[0] in ("--setup", "setup"):
        raise SystemExit(cli_setup())
    if args and args[0] in ("--restore-blocks", "restore-blocks"):
        raise SystemExit(cli_restore_blocks())
    if args and args[0] in ("--version", "-V"):
        print(f"netwatch {__version__}")
        raise SystemExit(0)
    if args and args[0] in ("--help", "-h"):
        print(f"Netwatch v{__version__} — home LAN / host exposure TUI")
        print("")
        print("Usage: netwatch                 Interactive dashboard")
        print("       netwatch --configure     Router username/password (+ optional SMTP)")
        print("       netwatch --setup         Credentials + sudo quarantine (run once)")
        print("       netwatch --new-user       Forgot login? New user (wipes all local data)")
        print("       netwatch --check         Scan + alert (cron-friendly)")
        print("       netwatch --restore-blocks  Re-apply quarantine after reboot")
        print("       netwatch --dig-listeners LAN listeners with process names")
        print("       netwatch --dig-port PORT Deep lookup (e.g. --dig-port 11434)")
        raise SystemExit(0)
    if args and args[0] in ("--dig-listeners", "dig-listeners"):
        raise SystemExit(cli_dig_listeners())
    if args and args[0] in ("--dig-port", "dig-port") and len(args) > 1:
        raise SystemExit(cli_dig_listeners(port=args[1]))

    cfg = load_config()
    require_local_auth(cfg)
    curses.wrapper(main)
