def load_secrets() -> dict[str, str]:
    secrets: dict[str, str] = {}
    if SECRETS_PATH.is_file():
        for line in SECRETS_PATH.read_text().splitlines():
            line = line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            key, val = line.split("=", 1)
            secrets[key.strip()] = val.strip()
    for key in ("ROUTER_USER", "ROUTER_PASSWORD", "NETWATCH_SMTP_USER", "NETWATCH_SMTP_PASS"):
        if key not in secrets and os.environ.get(key):
            secrets[key] = os.environ[key]
    return secrets


def save_secrets(secrets: dict[str, str]) -> None:
    SECRETS_PATH.parent.mkdir(parents=True, exist_ok=True)
    lines = ["# Netwatch secrets — chmod 600, never commit", ""]
    for key in (
        "ROUTER_USER",
        "ROUTER_PASSWORD",
        "NETWATCH_SMTP_USER",
        "NETWATCH_SMTP_PASS",
    ):
        val = (secrets.get(key) or "").strip()
        if val:
            lines.append(f"{key}={val}")
    SECRETS_PATH.write_text("\n".join(lines) + "\n")
    os.chmod(SECRETS_PATH, 0o600)


def prompt_yes_no(prompt: str, *, default: bool = False) -> bool:
    hint = "Y/n" if default else "y/N"
    ans = input(f"{prompt} [{hint}]: ").strip().lower()
    if not ans:
        return default
    return ans in ("y", "yes")


def configure_credentials(*, force_router: bool = False) -> int:
    """Interactive router (and optional SMTP) credential setup."""
    secrets = load_secrets()
    print("Netwatch // credential setup")
    print(f"File: {SECRETS_PATH} (mode 600, never commit to git)\n")

    has_router = bool(secrets.get("ROUTER_PASSWORD"))
    if has_router and not force_router:
        if not prompt_yes_no("Update router username/password?", default=False):
            skip_router = True
        else:
            skip_router = False
    else:
        skip_router = False
        if not has_router:
            print("→ Router login enables whole-house Wi‑Fi deny on supported gateways (e.g. ZTE).")
            print("  Skip if you only need PC-side quarantine.\n")

    if not skip_router:
        user = input("Router username [admin]: ").strip() or "admin"
        while True:
            password = getpass.getpass("Router password (empty to skip): ")
            if not password:
                if has_router and not force_router:
                    print("Keeping existing router password.")
                elif prompt_yes_no("Continue without router credentials?", default=True):
                    secrets.pop("ROUTER_USER", None)
                    secrets.pop("ROUTER_PASSWORD", None)
                else:
                    continue
                break
            confirm = getpass.getpass("Confirm router password: ")
            if password != confirm:
                print("Passwords do not match — try again.\n")
                continue
            secrets["ROUTER_USER"] = user
            secrets["ROUTER_PASSWORD"] = password
            break

    if prompt_yes_no("Configure email alert credentials (SMTP)?", default=False):
        smtp_user = input("SMTP username: ").strip()
        smtp_pass = getpass.getpass("SMTP password or app token: ")
        if smtp_user:
            secrets["NETWATCH_SMTP_USER"] = smtp_user
        if smtp_pass:
            secrets["NETWATCH_SMTP_PASS"] = smtp_pass

    save_secrets(secrets)
    if secrets.get("ROUTER_PASSWORD"):
        print(f"\n✓ Router credentials saved for user '{secrets.get('ROUTER_USER', 'admin')}'.")
    else:
        print("\n✓ Saved (no router password — PC-only block until you run --configure again).")
    print(f"  {SECRETS_PATH}")
    return 0


def cli_configure() -> int:
    return configure_credentials()


PBKDF2_ITERATIONS = 600_000


def hash_password(password: str, *, salt: bytes | None = None) -> str:
    salt = salt or secrets.token_bytes(16)
    digest = hashlib.pbkdf2_hmac(
        "sha256",
        password.encode("utf-8"),
        salt,
        PBKDF2_ITERATIONS,
    )
    return f"pbkdf2_sha256${PBKDF2_ITERATIONS}${salt.hex()}${digest.hex()}"


def verify_password(password: str, stored: str) -> bool:
    try:
        algo, iters_s, salt_hex, hash_hex = stored.split("$", 3)
        if algo != "pbkdf2_sha256":
            return False
        iterations = int(iters_s)
        salt = bytes.fromhex(salt_hex)
        expected = bytes.fromhex(hash_hex)
    except (TypeError, ValueError):
        return False
    computed = hashlib.pbkdf2_hmac(
        "sha256",
        password.encode("utf-8"),
        salt,
        iterations,
    )
    return secrets.compare_digest(computed, expected)


def load_auth_record() -> dict[str, Any] | None:
    if not AUTH_PATH.is_file():
        return None
    try:
        data = json.loads(AUTH_PATH.read_text())
    except (json.JSONDecodeError, OSError):
        return None
    if not isinstance(data, dict) or not data.get("username") or not data.get("password_hash"):
        return None
    return data


def save_auth_record(username: str, password: str) -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    payload = {
        "username": username.strip(),
        "password_hash": hash_password(password),
        "version": 1,
        "created_at": time.strftime("%Y-%m-%dT%H:%M:%S"),
    }
    AUTH_PATH.write_text(json.dumps(payload, indent=2) + "\n")
    os.chmod(AUTH_PATH, 0o600)


def local_auth_enabled(cfg: dict[str, Any] | None = None) -> bool:
    cfg = cfg or load_config()
    return bool(cfg.get("auth", {}).get("enabled", True))


def setup_local_auth(*, warn_recovery: bool = True) -> None:
    print("Netwatch // create your local login")
    print("This protects the dashboard on this PC (not your router admin password).")
    print(f"Credentials stored hashed in {AUTH_PATH}")
    if warn_recovery:
        print(
            "\n⚠ There is NO password recovery. If you forget your login, it is lost forever."
        )
        print("  Your only option is  netwatch --new-user  — which erases all local data.\n")
    username = ""
    while not username.strip():
        username = input("Choose username: ").strip()
        if not username:
            print("Username cannot be empty.\n")
    while True:
        password = getpass.getpass("Choose password: ")
        if len(password) < 8:
            print("Use at least 8 characters.\n")
            continue
        confirm = getpass.getpass("Confirm password: ")
        if password != confirm:
            print("Passwords do not match — try again.\n")
            continue
        break
    save_auth_record(username, password)
    print(f"\n✓ Local login created for '{username}'.")
    print("  Password stored as a one-way hash — it cannot be read back or reset.")


def wipe_local_user_data(cfg: dict[str, Any] | None = None) -> list[str]:
    """Erase all netwatch data tied to the previous local user."""
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    wiped: list[str] = []
    cfg = cfg or load_config()

    paths_empty: list[tuple[Path, str]] = [
        (AUTH_PATH, ""),
        (BLOCKED_PATH, "{}\n"),
        (TRUSTED_PEERS_PATH, "{}\n"),
        (MANUAL_PATH, "[]\n"),
        (ALERT_STATE_PATH, '{"notified_macs": {}}\n'),
        (expand_path(cfg["alerts"]["state_file"]), "{}\n"),
        (
            SECRETS_PATH,
            "# Netwatch secrets — chmod 600, never commit\n\nROUTER_USER=\nROUTER_PASSWORD=\n",
        ),
    ]
    for path, content in paths_empty:
        if content:
            path.write_text(content)
            if path == SECRETS_PATH or path == AUTH_PATH:
                os.chmod(path, 0o600)
        else:
            path.unlink(missing_ok=True)
        wiped.append(str(path))

    if cfg.get("prompts", {}).get("dismissed"):
        cfg.setdefault("prompts", {})["dismissed"] = {}
        save_config(cfg)
        wiped.append("config.yaml (prompt dismissals)")

    return wiped


def require_local_auth(cfg: dict[str, Any] | None = None) -> None:
    if not local_auth_enabled(cfg):
        return
    record = load_auth_record()
    if not record:
        setup_local_auth()
        return
    username = str(record["username"])
    for attempt in range(1, 4):
        entered_user = input(f"Username [{username}]: ").strip() or username
        entered_pass = getpass.getpass("Password: ")
        if secrets.compare_digest(entered_user, username) and verify_password(
            entered_pass, str(record["password_hash"])
        ):
            return
        remaining = 3 - attempt
        if remaining:
            print(f"Invalid login — {remaining} attempt(s) left.\n")
    print(
        "\nAuthentication failed. There is no password recovery — a forgotten login is lost forever."
    )
    print("To start over with a new user (all labels, blocks, secrets, and alerts erased):")
    print("  netwatch --new-user")
    raise SystemExit(1)


def cli_new_user() -> int:
    if not AUTH_PATH.is_file():
        print("No local login yet — run netwatch to create one.")
        return 1
    print("Netwatch // new local user")
    print(
        "⚠ This does NOT recover your old password — that login is gone forever."
    )
    print("⚠ All local netwatch data on this PC will be erased:")
    print("    device labels, block registry, router-manual names, secrets, alert history")
    print("")
    if not prompt_yes_no("Erase everything and create a new login?", default=False):
        print("Cancelled — existing data kept.")
        return 1
    if not prompt_yes_no("Are you sure? This cannot be undone.", default=False):
        print("Cancelled.")
        return 1
    cfg = load_config()
    wiped = wipe_local_user_data(cfg)
    print("\nErased:")
    for path in wiped:
        print(f"  · {path}")
    print("")
    setup_local_auth(warn_recovery=True)
    print("\nRun netwatch --configure and netwatch --setup again if you need router block / sudo.")
    return 0


def sudoers_content(user: str) -> str:
    nft = shutil.which("nft") or "/usr/sbin/nft"
    fw = shutil.which("firewall-cmd") or "/usr/bin/firewall-cmd"
    ss_bin = shutil.which("ss") or "/usr/sbin/ss"
    lsof_bin = shutil.which("lsof") or "/usr/bin/lsof"
    fuser_bin = shutil.which("fuser") or "/usr/sbin/fuser"
    return (
        f"# Installed by netwatch --setup\n"
        f"{user} ALL=(root) NOPASSWD: {nft}\n"
        f"{user} ALL=(root) NOPASSWD: {fw}\n"
        f"{user} ALL=(root) NOPASSWD: {ss_bin}\n"
        f"{user} ALL=(root) NOPASSWD: {lsof_bin}\n"
        f"{user} ALL=(root) NOPASSWD: {fuser_bin}\n"
    )


def install_enforcement_privileges(user: str | None = None) -> tuple[bool, str]:
    user = user or os.environ.get("USER") or "root"
    content = sudoers_content(user)
    path = f"/etc/sudoers.d/netwatch-{user}"
    tmp = CONFIG_DIR / ".sudoers.tmp"
    tmp.write_text(content)
    try:
        proc = subprocess.run(
            ["pkexec", "bash", "-c", f"install -m 440 {tmp} {path} && visudo -cf {path}"],
            capture_output=True,
            text=True,
            timeout=120,
            check=False,
        )
        if proc.returncode != 0:
            err = (proc.stderr or proc.stdout or "pkexec failed").strip()
            return False, err[:200]
        SETUP_MARKER.write_text(time.strftime("%Y-%m-%dT%H:%M:%S") + "\n")
        return True, f"installed {path}"
    except (subprocess.TimeoutExpired, OSError) as exc:
        return False, str(exc)[:200]
    finally:
        tmp.unlink(missing_ok=True)


def install_systemd_restore() -> tuple[bool, str]:
    unit = (
        "[Unit]\n"
        "Description=Restore netwatch quarantine rules after login\n"
        "After=network-online.target\n"
        "\n"
        "[Service]\n"
        "Type=oneshot\n"
        f"ExecStart={Path.home() / '.local/bin/netwatch'} --restore-blocks\n"
        "RemainAfterExit=yes\n"
        "\n"
        "[Install]\n"
        "WantedBy=default.target\n"
    )
    SYSTEMD_USER_UNIT.parent.mkdir(parents=True, exist_ok=True)
    SYSTEMD_USER_UNIT.write_text(unit)
    try:
        subprocess.run(["systemctl", "--user", "daemon-reload"], check=False, timeout=10)
        subprocess.run(["systemctl", "--user", "enable", "netwatch-blocks.service"], check=False, timeout=10)
        return True, "systemd user restore enabled"
    except (subprocess.TimeoutExpired, OSError) as exc:
        return False, str(exc)[:200]


def ensure_enforcement_ready(cfg: dict[str, Any], *, interactive: bool = False) -> tuple[bool, str]:
    del interactive  # setup only via netwatch --setup or explicit TUI consent
    cm = cfg.get("countermeasures", {})
    if not cm.get("enabled", True):
        return True, "countermeasures disabled"

    if SETUP_MARKER.is_file():
        return True, "enforcement ready"

    return False, "run: netwatch --setup"


def cli_setup(cfg: dict[str, Any] | None = None) -> int:
    cfg = cfg or load_config()
    print(f"Netwatch enforcement setup (v{__version__})")
    print("Step 1/2 — credentials")
    if not load_secrets().get("ROUTER_PASSWORD"):
        configure_credentials(force_router=False)
    elif prompt_yes_no("\nRe-run credential setup before sudo install?", default=False):
        configure_credentials(force_router=False)
    print("\nStep 2/2 — system privileges (one GUI password prompt)")
    print("→ Installing passwordless nft/firewalld/ss/lsof access…")
    ok, msg = install_enforcement_privileges()
    print(msg)
    if not ok:
        return 1

    ok2, msg2 = True, "restore on boot disabled (manual quarantine only)"
    if cfg.get("countermeasures", {}).get("restore_on_boot"):
        ok2, msg2 = install_systemd_restore()
    else:
        SYSTEMD_USER_UNIT.unlink(missing_ok=True)
        subprocess.run(["systemctl", "--user", "disable", "netwatch-blocks.service"], check=False)
    print(msg2)
    print("Done. Press B on dashboard to quarantine unknown devices.")
    return 0


@dataclass
class CapabilityGap:
    prompt_id: str
    title: str
    body: list[str]
    packages: list[str] = field(default_factory=list)
    setup: bool = False
    dismiss_proceeds: bool = True


def prompt_dismissed(cfg: dict[str, Any], prompt_id: str) -> bool:
    dismissed = (cfg.get("prompts") or {}).get("dismissed") or {}
    return bool(dismissed.get(prompt_id))


def dismiss_prompt(cfg: dict[str, Any], prompt_id: str) -> None:
    cfg.setdefault("prompts", {}).setdefault("dismissed", {})[prompt_id] = True
    save_config(cfg)


def install_os_packages(packages: list[str]) -> tuple[bool, str]:
    pkgs = [p for p in packages if p]
    if not pkgs:
        return True, "nothing to install"
    if not shutil.which("dnf"):
        return False, "install manually: sudo dnf install " + " ".join(pkgs)
    if not shutil.which("pkexec"):
        return False, "install manually: sudo dnf install " + " ".join(pkgs)
    try:
        proc = subprocess.run(
            ["pkexec", "dnf", "install", "-y", *pkgs],
            capture_output=True,
            text=True,
            timeout=600,
            check=False,
        )
    except (subprocess.TimeoutExpired, OSError) as exc:
        return False, str(exc)[:180]
    if proc.returncode != 0:
        err = (proc.stderr or proc.stdout or "dnf install failed").strip()
        return False, err[:200]
    return True, f"installed {' '.join(pkgs)}"


def run_tui_setup(cfg: dict[str, Any]) -> tuple[bool, str]:
    ok, msg = install_enforcement_privileges()
    if not ok:
        return ok, msg
    if cfg.get("countermeasures", {}).get("restore_on_boot"):
        ok2, msg2 = install_systemd_restore()
        if not ok2:
            return ok, f"{msg}; restore: {msg2}"
    return True, msg


