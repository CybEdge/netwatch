    return max(1, int(cfg.get("display", {}).get("items_per_panel") or 15))


def panel_page_count(total_panels: int, cfg: dict[str, Any]) -> int:
    per = panels_per_page(cfg)
    return max(1, (total_panels + per - 1) // per)


def advance_panel_page(current: int, total_panels: int, cfg: dict[str, Any]) -> int:
    pages = panel_page_count(total_panels, cfg)
    return (current + 1) % pages


def retreat_panel_page(current: int, total_panels: int, cfg: dict[str, Any]) -> int:
    pages = panel_page_count(total_panels, cfg)
    return (current - 1) % pages


@dataclass
class DashboardPanel:
    panel_id: str
    title: str
    pair: int
    lines: list[str]
    line_attrs: list[int] | None = None
    total: int = 0


def build_dashboard_panels(
    cfg: dict[str, Any],
    dash: DashboardState,
    scanned: bool,
) -> list[DashboardPanel]:
    """Build all panel containers dynamically from config + live state."""
    cap = items_per_panel(cfg)
    panels: list[DashboardPanel] = []
    he = cfg.get("host_exposure", {})
    router_on = cfg["router"].get("enabled") and (cfg["router"].get("type") or "disabled").lower() != "disabled"

    lan_lines: list[str] = []
    lan_attrs: list[int] = []
    if scanned:
        lan_lines.append("◈ post house-scan sweep")
        lan_attrs.append(cp(CP_MAGENTA, bold=True))
    for d in dash.devices[:cap]:
        tag = " ▸NEW" if d.is_new else ""
        if is_blocked_mac(cfg, d.mac):
            tag = " ⛔BLOCK"
        name = (d.label or d.guess or d.hostname or "?")[:14]
        lan_lines.append(f"{d.ip:<15} {name:<14}{tag}")
        lan_attrs.append(_lan_line_attr(d, scanned))
    panels.append(
        DashboardPanel(
            "lan",
            "LAN :: nodes",
            CP_CYAN,
            lan_lines or ["(no nodes — S·house scan)"],
            lan_attrs or None,
            total=len(dash.devices),
        )
    )

    if cfg["tailscale"].get("enabled", True):
        ts_lines: list[str] = []
        ts_attrs: list[int] = []
        for p in dash.tailscale[:cap]:
            glyph = "◉" if p.online else "○"
            ts_lines.append(f"{glyph} {p.name[:18]:<18} {p.ip}")
            ts_attrs.append(cp(CP_GREEN, bold=True) if p.online else cp(CP_BLUE, dim=True))
        panels.append(
            DashboardPanel(
                "tailscale",
                "MESH :: tailscale",
                CP_MAGENTA,
                ts_lines or ["(mesh offline)"],
                ts_attrs or None,
                total=len(dash.tailscale),
            )
        )

    if router_on:
        rlines = [f"◈ {(c.name or '?')[:12]:<12} {c.ip}" for c in dash.router_clients[:cap]]
        panels.append(
            DashboardPanel(
                "router",
                "ROUTER :: dhcp",
                CP_YELLOW,
                rlines or ["(no uplink data)"],
                total=len(dash.router_clients),
            )
        )

    out_w = 36
    out_lines = format_outbound_lines(dash.outbound, out_w, limit=cap)
    panels.append(
        DashboardPanel(
            "outbound",
            "NET :: outbound",
            CP_GREEN,
            out_lines,
            total=len(dash.outbound),
        )
    )

    if he.get("enabled", True):
        if he.get("monitor_inbound", True):
            in_lines = format_inbound_lines(dash.inbound, 32, limit=cap)
            in_attrs = [
                cp(CP_ALERT, bold=True) if f.is_new else cp(CP_WHITE, dim=True)
                for f in dash.inbound[:cap]
            ]
            if in_lines and in_lines[0].startswith("REMOTE"):
                in_attrs = [cp(CP_CYAN, dim=True)] + (in_attrs or [])
            panels.append(
                DashboardPanel(
                    "inbound",
                    "HOST :: inbound",
                    CP_ALERT,
                    in_lines or ["(no inbound sessions)"],
                    in_attrs,
                    total=len(dash.inbound),
                )
            )

        if he.get("monitor_listeners", True):
            exp_lines = [
                f"{'!' if e.risk == 'alert' else '·'} :{e.port} {format_listener_label(e)}"[:34]
                for e in dash.exposed[:cap]
            ]
            panels.append(
                DashboardPanel(
                    "exposed",
                    "HOST :: exposed",
                    CP_YELLOW,
                    exp_lines or ["(no LAN listeners)"],
                    total=len(dash.exposed),
                )
            )

        if he.get("monitor_bridges", True):
            path_lines: list[str] = []
            for b in dash.bridges[:cap]:
                path_lines.append(f"◈ {b.name} ({b.state})")
                path_lines.append(f"  {b.note[:30]}")
            if dash.login_sessions:
                path_lines.append("── logins ──")
                path_lines.extend(dash.login_sessions[: max(1, cap // 3)])
            panels.append(
                DashboardPanel(
                    "paths",
                    "HOST :: paths",
                    CP_MAGENTA,
                    path_lines or ["(no bridges/tunnels)"],
                    total=len(dash.bridges) + len(dash.login_sessions),
                )
            )

    defense = [f"◈ fw · {firewall_state()[:22]}"]
    defense.extend(quarantine_lines(dash.blocked, min(cap, 8)))
    defense.extend(failed_logins()[: max(0, cap - len(defense))])
    panels.append(
        DashboardPanel(
            "defense",
            "DEF :: perimeter",
            CP_ALERT,
            defense,
            total=len(dash.blocked),
        )
    )

    return panels


