def run(cmd: list[str], timeout: int = 8) -> str:
    try:
        proc = subprocess.run(
            cmd, capture_output=True, text=True, timeout=timeout, check=False
        )
        return (proc.stdout or proc.stderr or "").strip()
    except (subprocess.TimeoutExpired, FileNotFoundError, KeyboardInterrupt):
        return ""


def default_route() -> tuple[str, str, str]:
    out = run(["ip", "route", "show", "default"])
    iface = gateway = ""
    m = re.search(r"default via (\S+) dev (\S+)", out)
    if m:
        gateway, iface = m.group(1), m.group(2)
    local = ""
    if iface:
        addr = run(["ip", "-4", "-br", "addr", "show", "dev", iface])
        m2 = re.search(r"(\d+\.\d+\.\d+\.\d+)", addr)
        if m2:
            local = m2.group(1)
    return iface, gateway, local


def parse_neigh(iface: str) -> list[LanDevice]:
    devices: list[LanDevice] = []
    out = run(["ip", "neigh", "show", "dev", iface])
    for line in out.splitlines():
        parts = line.split()
        if len(parts) < 4 or parts[0].count(".") != 3 or parts[1] != "lladdr":
            continue
        ip, mac, state = parts[0], parts[2].lower(), parts[-1]
        if mac == "failed":
            continue
        devices.append(LanDevice(ip=ip, mac=mac, state=state))
    devices.sort(key=lambda d: ipaddress.ip_address(d.ip))
    return devices


def is_random_mac(mac: str) -> bool:
    try:
        first = int(mac.split(":")[0], 16)
    except ValueError:
        return False
    return bool(first & 0x02)


def ensure_oui_cache(cfg: dict[str, Any]) -> Path:
    cache = expand_path(cfg["identify"]["oui_cache"])
    if cache.is_file() and cache.stat().st_size > 1000:
        return cache
    cache.parent.mkdir(parents=True, exist_ok=True)
    url = cfg["identify"].get(
        "oui_url", "https://www.wireshark.org/download/automated/data/manuf"
    )
    try:
        with urlopen(url, timeout=30) as resp:
            cache.write_bytes(resp.read())
    except URLError:
        pass
    return cache


def load_oui_prefixes(cfg: dict[str, Any]) -> dict[str, str]:
    global _OUI_PREFIXES
    if _OUI_PREFIXES is not None:
        return _OUI_PREFIXES
    prefixes: dict[str, str] = {}
    for candidate in (
        expand_path(cfg["identify"]["oui_cache"]),
        Path("/usr/share/nmap/nmap-mac-prefixes"),
        Path("/usr/share/wireshark/manuf"),
    ):
        if candidate.is_file():
            for line in candidate.read_text(errors="replace").splitlines():
                line = line.strip()
                if not line or line.startswith("#"):
                    continue
                parts = line.split(None, 2)
                if len(parts) >= 2 and ":" in parts[0]:
                    prefixes[parts[0].upper().replace("-", ":")] = parts[1]
            if prefixes:
                _OUI_PREFIXES = prefixes
                return prefixes
    ensure_oui_cache(cfg)
    return load_oui_prefixes(cfg) if expand_path(cfg["identify"]["oui_cache"]).is_file() else {}


def lookup_vendor(mac: str, cfg: dict[str, Any]) -> str:
    prefixes = load_oui_prefixes(cfg)
    mac = mac.upper()
    for width in (8, 7, 6):
        key = mac[:width]
        if key in prefixes:
            return prefixes[key]
    return ""


def resolve_hostname(ip: str, timeout: float = 1.0) -> str:
    t = max(1, int(timeout))
    if shutil.which("avahi-resolve"):
        out = run(["avahi-resolve", "-a", ip], timeout=t)
        if out and "\t" in out:
            name = out.split("\t", 1)[1].strip()
            if name and name != ip:
                return name
    old = socket.getdefaulttimeout()
    try:
        socket.setdefaulttimeout(timeout)
        name, _, _ = socket.gethostbyaddr(ip)
        if name and name != ip:
            return name
    except OSError:
        pass
    finally:
        socket.setdefaulttimeout(old)
    return ""


def probe_tcp_port(ip: str, port: int, timeout: float = 0.35) -> bool:
    try:
        with socket.create_connection((ip, port), timeout=timeout):
            return True
    except OSError:
        return False


