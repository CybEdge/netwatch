CASE_SENSITIVE_BINDINGS = frozenset({"panel_next", "panel_prev"})


def binding_key(cfg: dict[str, Any], action: str) -> str:
    custom = (cfg.get("keybindings") or {}).get(action)
    if isinstance(custom, str) and len(custom) == 1:
        return custom
    return DEFAULT_KEYBINDINGS[action][1]


def binding_label(cfg: dict[str, Any], action: str) -> str:
    key = binding_key(cfg, action)
    if key.isalpha() and action not in CASE_SENSITIVE_BINDINGS:
        return key.upper()
    return key


def binding_ch(cfg: dict[str, Any], action: str) -> int:
    return ord(binding_key(cfg, action))


def printable_key(ch: int) -> bool:
    return 32 <= ch <= 126 and ch not in (127,)


def key_matches_action(cfg: dict[str, Any], ch: int, action: str) -> bool:
    bound = binding_ch(cfg, action)
    if ch == bound:
        return True
    if action in CASE_SENSITIVE_BINDINGS:
        return False
    if not printable_key(ch):
        return False
    key = binding_key(cfg, action)
    if key.isalpha() and chr(ch).lower() == key.lower():
        return True
    return False


def action_for_key(cfg: dict[str, Any], ch: int, *, exclude: str | None = None) -> str | None:
    for action in DEFAULT_KEYBINDINGS:
        if action == exclude:
            continue
        if key_matches_action(cfg, ch, action):
            return action
    return None


def set_keybinding(cfg: dict[str, Any], action: str, ch: int) -> str:
    if not printable_key(ch):
        return "unsupported key — use a printable character"
    new_key = chr(ch)
    other = action_for_key(cfg, ch, exclude=action)
    cfg.setdefault("keybindings", {})
    if other:
        old = binding_key(cfg, action)
        cfg["keybindings"][action] = new_key
        cfg["keybindings"][other] = old
        return f"swapped {binding_label(cfg, action)} ↔ {binding_label(cfg, other)}"
    cfg["keybindings"][action] = new_key
    return f"bound {DEFAULT_KEYBINDINGS[action][0]} → {binding_label(cfg, action)}"


def binding_rows(cfg: dict[str, Any]) -> list[tuple[str, str, str]]:
    return [
        (action, binding_label(cfg, action), DEFAULT_KEYBINDINGS[action][0])
        for action in DEFAULT_KEYBINDINGS
    ]


